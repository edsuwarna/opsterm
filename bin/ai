#!/usr/bin/env python3
"""
OpsTerm — AI Terminal Assistant
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
Zero-dependency CLI tool: custom AI provider + saved servers, workflows,
multi-hop SSH, SCP, vault, and shell integration.

Usage:
  ai <prompt>              Ask AI anything (default mode)
  ai ssh <server> [--via <proxy>]   SSH ke server (via jump host opsional)
  ai scp <src> <dst>       Upload/download file via server
  ai run <workflow>        Jalanin multi-step workflow
  ai servers               Manage server list
  ai workflows             Manage workflow list
  ai config                Manage config
  ai vault                 Encrypted credentials
  ai last                  Lihat output command terakhir
  ai explain-last          Explain output pake AI
  ai history               Riwayat command
  ai init                  Setup awal
  ai completion bash|zsh   Generate completion script
  <cmd> | ai <prompt>      Pipe mode
"""

import argparse
import base64
import hashlib
import hmac
import json
import os
import shlex
import sqlite3
import subprocess
import sys
import textwrap
import time
import urllib.request
import urllib.error
from pathlib import Path
from typing import Any, Dict, List, Optional, Tuple

# ── Optional cryptography for vault ────────────────────────
try:
    from cryptography.fernet import Fernet
    from cryptography.hazmat.primitives import hashes as crypt_hashes
    from cryptography.hazmat.primitives.kdf.pbkdf2 import PBKDF2HMAC
    HAS_CRYPTOGRAPHY = True
except ImportError:
    HAS_CRYPTOGRAPHY = False

# ── Paths ──────────────────────────────────────────────────
HOME = Path.home()
CONFIG_DIR = Path(os.environ.get("OPSTERM_DIR", HOME / ".ai-workflows"))
CONFIG_DIR.mkdir(parents=True, exist_ok=True)

CONFIG_FILE = CONFIG_DIR / "config.yaml"
SERVERS_FILE = CONFIG_DIR / "servers.yaml"
WORKFLOWS_FILE = CONFIG_DIR / "workflows.yaml"
HISTORY_DB = CONFIG_DIR / "history.db"
VAULT_FILE = CONFIG_DIR / "vault.json"
LAST_OUTPUT_FILE = CONFIG_DIR / "last_output.txt"
LAST_CMD_FILE = CONFIG_DIR / "last_command.txt"

# ═══════════════════════════════════════════════════════════
# MINIMAL YAML PARSER
# ═══════════════════════════════════════════════════════════

def _parse_yaml(text: str) -> Any:
    """Parse a subset of YAML: scalars, mappings, lists, nesting via indent."""
    lines = text.split("\n")
    cleaned = []
    for line in lines:
        stripped = line.rstrip()
        if "#" in stripped:
            idx = stripped.index("#")
            before = stripped[:idx]
            if before.count('"') % 2 == 0 and before.count("'") % 2 == 0:
                stripped = before.rstrip()
        cleaned.append(stripped)
    while cleaned and cleaned[0] == "":
        cleaned.pop(0)
    if not cleaned:
        return {}

    def _parse_block(lines, start, base_indent):
        if start >= len(lines):
            return None, start
        line = lines[start]
        if line.strip() == "":
            return None, start + 1
        indent = len(line) - len(line.lstrip())
        content = line.strip()

        if content.startswith("- "):
            items = []
            i = start
            while i < len(lines):
                l = lines[i]
                if l.strip() == "":
                    i += 1; continue
                indent_i = len(l) - len(l.lstrip())
                if indent_i < indent:
                    break
                if l.strip().startswith("- "):
                    item_text = l.strip()[2:]
                    if ": " in item_text and not item_text.startswith('"') and not item_text.startswith("'"):
                        key, val = item_text.split(": ", 1)
                        obj = {key.strip(): _parse_scalar(val.strip())}
                        j = i + 1
                        while j < len(lines):
                            l2 = lines[j]
                            if l2.strip() == "":
                                j += 1; continue
                            indent_j = len(l2) - len(l2.lstrip())
                            if indent_j <= indent:
                                break
                            if indent_j == indent + 2 and ": " in l2.strip():
                                k, v = l2.strip().split(": ", 1)
                                obj[k.strip()] = _parse_scalar(v.strip())
                                j += 1
                            else:
                                break
                        items.append(obj)
                        i = j
                    else:
                        items.append(_parse_scalar(item_text))
                        i += 1
                else:
                    break
            return items, i

        if ": " in content or content.endswith(":"):
            result = {}
            i = start
            while i < len(lines):
                l = lines[i]
                if l.strip() == "":
                    i += 1; continue
                indent_i = len(l) - len(l.lstrip())
                if indent_i < base_indent:
                    break
                if ": " in l.strip() or l.strip().endswith(":"):
                    k, v = (l.strip().split(": ", 1) if ": " in l.strip() else (l.strip()[:-1], ""))
                    k = k.strip()
                    if v == "":
                        v, i = _parse_block(lines, i + 1, indent_i + 2)
                        if v is None:
                            v = {}
                        result[k] = v
                    else:
                        result[k] = _parse_scalar(v.strip())
                        i += 1
                else:
                    break
            return result, i

        return _parse_scalar(content), start + 1

    val, _ = _parse_block(cleaned, 0, 0)
    return val if val is not None else {}

def _parse_scalar(text: str) -> Any:
    if not text:
        return ""
    if (text.startswith('"') and text.endswith('"')) or \
       (text.startswith("'") and text.endswith("'")):
        return text[1:-1]
    try:
        if "." in text:
            return float(text)
        return int(text)
    except ValueError:
        pass
    if text.lower() in ("true", "yes", "on"):
        return True
    if text.lower() in ("false", "no", "off"):
        return False
    if text.lower() in ("null", "~"):
        return None
    return text

def _dump_yaml(obj: Any, indent: int = 0) -> str:
    prefix = "  " * indent
    if isinstance(obj, dict):
        lines = []
        for k, v in obj.items():
            if isinstance(v, (dict, list)):
                if v:
                    lines.append(f"{prefix}{k}:")
                    lines.append(_dump_yaml(v, indent + 1))
                else:
                    lines.append(f"{prefix}{k}: {{}}")
            else:
                lines.append(f"{prefix}{k}: {_dump_scalar(v)}")
        return "\n".join(lines)
    elif isinstance(obj, list):
        lines = []
        for item in obj:
            if isinstance(item, dict):
                if item:
                    first = True
                    for k, v in item.items():
                        if first:
                            lines.append(f"{prefix}- {k}: {_dump_scalar(v)}")
                            first = False
                        else:
                            lines.append(f"{prefix}  {k}: {_dump_scalar(v)}")
                else:
                    lines.append(f"{prefix}- {{}}")
            else:
                lines.append(f"{prefix}- {_dump_scalar(item)}")
        return "\n".join(lines)
    else:
        return f"{prefix}{_dump_scalar(obj)}"

def _dump_scalar(val: Any) -> str:
    if isinstance(val, bool):
        return "true" if val else "false"
    if val is None:
        return "~"
    if isinstance(val, str) and (val.startswith(" ") or val.endswith(" ") or
                                  val.startswith("#") or val == "" or
                                  ":" in val or val.lower() in ("true", "false", "yes", "no", "null")):
        return f'"{val}"'
    return str(val)

# ═══════════════════════════════════════════════════════════
# CONFIG LOADER
# ═══════════════════════════════════════════════════════════

def load_yaml(path: Path) -> dict:
    if path.exists():
        text = path.read_text(encoding="utf-8")
        val = _parse_yaml(text)
        return val if isinstance(val, dict) else {}
    return {}

def save_yaml(path: Path, data: dict):
    path.write_text(_dump_yaml(data) + "\n", encoding="utf-8")

def load_config() -> dict:
    cfg = load_yaml(CONFIG_FILE)
    defaults = {
        "ai": {
            "api_url": "https://api.deepseek.com/v1/chat/completions",
            "model": "deepseek-chat",
            "temperature": 0.3,
            "max_tokens": 1024,
        },
        "shell": {
            "confirm_before_exec": True,
            "auto_exec_patterns": ["^ssh ", "^kubectl ", "^docker ", "^cd "],
        },
    }
    ai = cfg.get("ai", {})
    for k, v in defaults.get("ai", {}).items():
        ai.setdefault(k, v)
    cfg["ai"] = ai
    shell = cfg.get("shell", {})
    for k, v in defaults.get("shell", {}).items():
        shell.setdefault(k, v)
    cfg["shell"] = shell
    env_key = os.environ.get("OPSTERM_API_KEY", "")
    if env_key:
        ai["api_key"] = env_key
    return cfg

def get_servers() -> dict:
    return load_yaml(SERVERS_FILE).get("servers", {})

def save_servers(servers: dict):
    save_yaml(SERVERS_FILE, {"servers": servers})

def get_workflows() -> dict:
    return load_yaml(WORKFLOWS_FILE).get("workflows", {})

def save_workflows(workflows: dict):
    save_yaml(WORKFLOWS_FILE, {"workflows": workflows})

def _fuzzy_match(name: str, items: dict) -> Optional[str]:
    """Find item by exact name or fuzzy match."""
    if name in items:
        return name
    matches = [k for k in items if name in k]
    if len(matches) == 1:
        return matches[0]
    if len(matches) > 1:
        print(f"❌ Banyak yang cocok '{name}': {', '.join(matches)}")
        return None
    return None

# ═══════════════════════════════════════════════════════════
# SQLITE HISTORY
# ═══════════════════════════════════════════════════════════

def init_db():
    conn = sqlite3.connect(str(HISTORY_DB))
    conn.execute("""
        CREATE TABLE IF NOT EXISTS history (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            timestamp TEXT DEFAULT (datetime('now','localtime')),
            mode TEXT,
            input TEXT,
            output TEXT
        )
    """)
    conn.commit()
    return conn

def add_history(mode: str, inp: str, out: str = ""):
    try:
        conn = init_db()
        conn.execute("INSERT INTO history (mode, input, output) VALUES (?, ?, ?)",
                     (mode, inp[:500], out[:2000]))
        conn.commit()
        conn.close()
    except Exception:
        pass

def show_history(limit: int = 20):
    conn = init_db()
    rows = conn.execute(
        "SELECT id, timestamp, mode, input FROM history ORDER BY id DESC LIMIT ?",
        (limit,)
    ).fetchall()
    conn.close()
    if not rows:
        print("📭 Belum ada riwayat.")
        return
    for rid, ts, mode, inp in reversed(rows):
        icon = {"ai": "🤖", "ssh": "🔑", "workflow": "⚡", "shell": "💻",
                "pipe": "🔗", "scp": "📁", "vault": "🔐"}.get(mode, "❓")
        inp_short = inp[:60] + "..." if len(inp) > 60 else inp
        print(f"  [{rid}] {icon} {ts} [{mode}] {inp_short}")

# ═══════════════════════════════════════════════════════════
# AI CLIENT
# ═══════════════════════════════════════════════════════════

def ai_chat(prompt: str, system: str = "", config: Optional[dict] = None) -> str:
    cfg = config or load_config()
    ai_cfg = cfg["ai"]
    api_key = ai_cfg.get("api_key", "")
    if not api_key:
        return "❌ API key belum di-set. Set di config.yaml atau export OPSTERM_API_KEY."
    messages = []
    if system:
        messages.append({"role": "system", "content": system})
    messages.append({"role": "user", "content": prompt})
    payload = {
        "model": ai_cfg.get("model", "deepseek-chat"),
        "messages": messages,
        "temperature": ai_cfg.get("temperature", 0.3),
        "max_tokens": ai_cfg.get("max_tokens", 1024),
        "stream": False,
    }
    req = urllib.request.Request(
        ai_cfg["api_url"],
        data=json.dumps(payload).encode("utf-8"),
        headers={
            "Content-Type": "application/json",
            "Authorization": f"Bearer {api_key}",
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=60) as resp:
            result = json.loads(resp.read().decode("utf-8"))
        return result["choices"][0]["message"]["content"].strip()
    except urllib.error.HTTPError as e:
        body = e.read().decode("utf-8", errors="replace")
        return f"❌ HTTP {e.code}: {body[:300]}"
    except Exception as e:
        return f"❌ Error: {e}"

# ═══════════════════════════════════════════════════════════
# SSH RUNNER — with multi-hop support
# ═══════════════════════════════════════════════════════════

def _server_lookup(name: str, servers: dict) -> Optional[dict]:
    """Find server by name (exact or fuzzy)."""
    exact = _fuzzy_match(name, servers)
    if exact:
        return servers[exact]
    print(f"❌ Server '{name}' tidak ditemukan.")
    print(f"   Gunakan: ai servers list")
    return None

def _build_ssh_cmd(s: dict, proxy_cmd: Optional[str] = None) -> List[str]:
    """Build SSH arg list from server config + optional proxy jump."""
    host = s.get("host", "")
    user = s.get("user", "root")
    port = s.get("port", 22)
    key = s.get("key", "")
    cmd = ["ssh"]
    if key:
        cmd.extend(["-i", os.path.expanduser(key)])
    if port != 22:
        cmd.extend(["-p", str(port)])
    # Multi-hop: -J flag (ProxyJump)
    if proxy_cmd:
        cmd.extend(["-J", proxy_cmd])
    cmd.append(f"{user}@{host}")
    return cmd

def _resolve_proxy(proxy_name: str, servers: dict) -> Optional[str]:
    """Resolve proxy server name to user@host[:port] string."""
    s = _server_lookup(proxy_name, servers)
    if not s:
        return None
    proxy_user = s.get("user", "root")
    proxy_host = s.get("host", "")
    proxy_port = s.get("port", 22)
    if proxy_port != 22:
        return f"{proxy_user}@{proxy_host}:{proxy_port}"
    return f"{proxy_user}@{proxy_host}"

def ssh_connect(server_name: str, servers: dict, proxy_name: str = "") -> Optional[List[str]]:
    """Resolve server config to SSH command list. Supports optional proxy jump."""
    s = _server_lookup(server_name, servers)
    if not s:
        return None

    # Check for proxy in config first, then CLI override
    proxy_str = ""
    if proxy_name:
        proxy_str = _resolve_proxy(proxy_name, servers)
        if proxy_str is None:
            return None
    elif s.get("proxy", ""):
        proxy_str = _resolve_proxy(s["proxy"], servers)
        if proxy_str is None:
            return None

    cmd = _build_ssh_cmd(s, proxy_str)
    cmd.append("-t")  # Force PTY
    return cmd

def run_ssh(cmd: List[str]):
    """Replace current process with SSH (interactive)."""
    os.execvp("ssh", cmd)

# ═══════════════════════════════════════════════════════════
# SCP FILE TRANSFER
# ═══════════════════════════════════════════════════════════

def _parse_scp_spec(spec: str, servers: dict) -> Tuple[Optional[str], str, str, int]:
    """Parse 'server:path' or '/local/path'. Returns (user@host, path, key, port) or (None, path, '', 0)."""
    if ":" in spec and not spec.startswith("/") and not spec.startswith("~"):
        server_part, path = spec.split(":", 1)
        s = _server_lookup(server_part, servers)
        if not s:
            return None, "", "", 0
        user = s.get("user", "root")
        host = s.get("host", "")
        key = s.get("key", "")
        port = s.get("port", 22)
        return f"{user}@{host}", path, key, port
    return None, spec, "", 0

def scp_transfer(source: str, dest: str, servers: dict, proxy_name: str = ""):
    """SCP file between local and remote, or between two remotes."""
    src_remote, src_path, src_key, src_port = _parse_scp_spec(source, servers)
    dst_remote, dst_path, dst_key, dst_port = _parse_scp_spec(dest, servers)

    # Build proxy jump
    proxy_str = ""
    if proxy_name:
        ps = _server_lookup(proxy_name, servers)
        if ps:
            proxy_str = _resolve_proxy(proxy_name, servers)

    cmd = ["scp"]
    # Add -o ProxyJump for multi-hop
    if proxy_str:
        cmd.extend(["-o", f"ProxyJump={proxy_str}"])
    # Add identity files
    if src_key:
        cmd.extend(["-i", os.path.expanduser(src_key)])
    if dst_key and dst_key != src_key:
        cmd.extend(["-i", os.path.expanduser(dst_key)])

    # Build source: [user@host]:path
    if src_remote:
        src_arg = f"{src_remote}:{src_path}"
        if src_port != 22:
            cmd.extend(["-P", str(src_port)])
    else:
        src_arg = src_path
    # Build destination
    if dst_remote:
        dst_arg = f"{dst_remote}:{dst_path}"
        if dst_port != 22:
            cmd.extend(["-P", str(dst_port)])
    else:
        dst_arg = dst_path

    cmd.append(src_arg)
    cmd.append(dst_arg)

    print(f"📁 SCP: {' → '.join([source, dest])}")
    result = subprocess.run(cmd)
    if result.returncode == 0:
        print("✅ Transfer selesai!")
    else:
        print(f"❌ Transfer gagal (exit code {result.returncode})")

# ═══════════════════════════════════════════════════════════
# VAULT — Encrypted Credentials
# ═══════════════════════════════════════════════════════════

class Vault:
    """Encrypted credential store using Fernet (AES-128-CBC) + PBKDF2."""

    def __init__(self):
        self._fernet = None
        self._unlocked = False

    def _load_data(self) -> dict:
        if VAULT_FILE.exists():
            try:
                return json.loads(VAULT_FILE.read_text())
            except (json.JSONDecodeError, ValueError):
                return {}
        return {}

    def _save_data(self, data: dict):
        VAULT_FILE.write_text(json.dumps(data, indent=2))

    def _derive_key(self, password: str, salt: bytes) -> bytes:
        """Derive a Fernet-compatible key using PBKDF2."""
        if HAS_CRYPTOGRAPHY:
            kdf = PBKDF2HMAC(
                algorithm=crypt_hashes.SHA256(),
                length=32,
                salt=salt,
                iterations=600_000,
            )
            return base64.urlsafe_b64encode(kdf.derive(password.encode()))
        return base64.urlsafe_b64encode(hashlib.pbkdf2_hmac(
            "sha256", password.encode(), salt, 600_000
        )[:32])

    def _get_password(self, confirm: bool = False) -> Optional[str]:
        """Read master password from env or prompt."""
        env_pw = os.environ.get("OPSTERM_VAULT_PASSWORD", "")
        if env_pw:
            return env_pw
        import getpass
        try:
            pw = getpass.getpass("🔐 Master password: ")
            if confirm:
                pw2 = getpass.getpass("🔐 Konfirmasi: ")
                if pw != pw2:
                    print("❌ Password tidak cocok!")
                    return None
        except (EOFError, getpass.GetPassWarning):
            # Non-interactive: fallback ke env var prompt
            print("❌ Non-interactive terminal detected.")
            print("   Set OPSTERM_VAULT_PASSWORD env var, or use:")
            print("   export OPSTERM_VAULT_PASSWORD='your-password'")
            return None
        return pw

    def init(self):
        """Initialize vault with a master password."""
        if VAULT_FILE.exists() and VAULT_FILE.stat().st_size > 10:
            resp = input("⚠️ Vault sudah ada. Reset? [y/N] ").strip().lower()
            if resp not in ("y", "yes"):
                return
        pw = self._get_password(confirm=True)
        if not pw:
            return
        salt = os.urandom(16)
        data = {
            "salt": base64.b64encode(salt).decode(),
            "keys": {},
        }
        self._save_data(data)
        # Verify by deriving key
        key = self._derive_key(pw, salt)
        print(f"✅ Vault initialized di {VAULT_FILE}")
        print("   Gunakan: ai vault set <key>")
        if not HAS_CRYPTOGRAPHY:
            print("   ⚠️  cryptography not installed — using fallback encryption")
            print("      Install: pip install cryptography")

    def _unlock(self) -> bool:
        """Unlock vault: derive key from password, return True on success."""
        if self._unlocked:
            return True
        pw = self._get_password()
        if not pw:
            return False
        data = self._load_data()
        if not data or "salt" not in data:
            print("❌ Vault belum di-init. Jalankan: ai vault init")
            return False
        salt = base64.b64decode(data["salt"])
        key = self._derive_key(pw, salt)
        # Test key by trying to decrypt something
        if HAS_CRYPTOGRAPHY:
            try:
                self._fernet = Fernet(key)
                # Verify by decrypting any existing value (or just store key)
                if data.get("keys"):
                    sample = next(iter(data["keys"].values()))
                    self._fernet.decrypt(sample["data"].encode())
                self._unlocked = True
                return True
            except Exception:
                print("❌ Wrong password!")
                return False
        else:
            # Fallback: HMAC-based verification
            self._fernet = key  # Store key bytes for later use
            self._unlocked = True
            return True

    def _encrypt(self, value: str) -> str:
        if HAS_CRYPTOGRAPHY and self._fernet:
            return self._fernet.encrypt(value.encode()).decode()
        # Fallback: XOR with HMAC integrity
        key = self._fernet
        iv = os.urandom(16)
        encrypted = iv + bytes([b ^ key[i % len(key)] for i, b in enumerate(value.encode())])
        mac = hmac.new(key, encrypted, "sha256").digest()
        return base64.b64encode(mac + encrypted).decode()

    def _decrypt(self, token: str) -> str:
        if HAS_CRYPTOGRAPHY and self._fernet:
            return self._fernet.decrypt(token.encode()).decode()
        key = self._fernet
        raw = base64.b64decode(token)
        mac, encrypted = raw[:32], raw[32:]
        expected_mac = hmac.new(key, encrypted, "sha256").digest()
        if not hmac.compare_digest(mac, expected_mac):
            raise ValueError("Data integrity check failed!")
        iv = encrypted[:16]
        return bytes([b ^ key[i % len(key)] for i, b in enumerate(encrypted[16:])]).decode()

    def set(self, key: str, value: str = ""):
        if not self._unlock():
            return
        if not value:
            import getpass
            try:
                value = getpass.getpass(f"🔑 Nilai untuk '{key}': ")
            except (EOFError, getpass.GetPassWarning):
                # Non-interactive: baca dari stdin
                value = sys.stdin.readline().strip()
        data = self._load_data()
        encrypted = self._encrypt(value)
        if "keys" not in data:
            data["keys"] = {}
        data["keys"][key] = {"data": encrypted}
        self._save_data(data)
        print(f"✅ Vault: '{key}' tersimpan!")

    def get(self, key: str) -> Optional[str]:
        if not self._unlock():
            return None
        data = self._load_data()
        entry = data.get("keys", {}).get(key)
        if not entry:
            print(f"❌ Key '{key}' tidak ditemukan di vault.")
            return None
        try:
            return self._decrypt(entry["data"])
        except Exception as e:
            print(f"❌ Decrypt gagal: {e}")
            return None

    def list_keys(self):
        data = self._load_data()
        keys = list(data.get("keys", {}).keys())
        if not keys:
            print("🔐 Vault kosong.")
            return
        print("🔐 Vault keys:")
        for k in sorted(keys):
            print(f"  • {k}")

    def rm(self, key: str):
        if not self._unlock():
            return
        data = self._load_data()
        if key in data.get("keys", {}):
            del data["keys"][key]
            self._save_data(data)
            print(f"✅ Key '{key}' dihapus dari vault.")
        else:
            print(f"❌ Key '{key}' tidak ditemukan.")

    def lock(self):
        self._fernet = None
        self._unlocked = False
        print("🔒 Vault locked.")

# ═══════════════════════════════════════════════════════════
# WORKFLOW EXECUTOR
# ═══════════════════════════════════════════════════════════

def run_workflow(name: str, workflows: dict, servers: dict, config: dict):
    exact = _fuzzy_match(name, workflows)
    if not exact:
        print(f"❌ Workflow '{name}' tidak ditemukan.")
        print(f"   Gunakan: ai workflows list")
        return
    name = exact
    wf = workflows[name]
    steps = wf.get("steps", [])
    total = len(steps)
    if not steps:
        print(f"⚠️ Workflow '{name}' tidak punya steps.")
        return

    print(f"⚡ Workflow: {name}")
    print(f"   {wf.get('desc', '')}")
    print(f"   {total} step(s)\n")

    for i, step in enumerate(steps, 1):
        desc = step.get("desc", "")
        command = step.get("command", "")
        ssh_target = step.get("ssh", "")
        scp_src = step.get("scp", "")
        scp_dst = step.get("to", "")
        scp_from = step.get("from", "local")
        need_confirm = step.get("confirm", False)
        wait_sec = step.get("wait", 0)

        print(f"  [{i}/{total}] {desc or command[:60]}")

        if need_confirm:
            resp = input("    Lanjut? [Y/n] ").strip().lower()
            if resp in ("n", "no"):
                print("    ⏭️  Skipped.")
                continue

        # SCP step
        if scp_src and scp_dst:
            source_spec = f"{scp_from}:{scp_src}" if scp_from != "local" else scp_src
            dest_spec = f"{ssh_target}:{scp_dst}" if ssh_target else scp_dst
            print(f"    📁 {source_spec} → {dest_spec}")
            scp_transfer(source_spec, dest_spec, servers)
            add_history("scp", f"{source_spec} → {dest_spec}")
            continue

        # SSH step
        if ssh_target:
            ssh_cmd = ssh_connect(ssh_target, servers)
            if ssh_cmd is None:
                return
            full_cmd = ssh_cmd[:-1]  # Remove -t
            full_cmd.append(f"cd /home/ubuntu && {command}")
            print(f"    🔑 {ssh_target} $ {command}")
            result = subprocess.run(full_cmd, capture_output=False)
            if result.returncode != 0:
                print(f"    ❌ Step {i} gagal (exit code {result.returncode})")
                if i < total:
                    cont = input("    Lanjut ke step selanjutnya? [y/N] ").strip().lower()
                    if cont not in ("y", "yes"):
                        print("⛔ Workflow dihentikan.")
                        return
        # Local command
        elif command:
            print(f"    $ {command}")
            result = subprocess.run(command, shell=True, capture_output=False)
            if result.returncode != 0:
                print(f"    ❌ Step {i} gagal (exit code {result.returncode})")
                if i < total:
                    cont = input("    Lanjut? [y/N] ").strip().lower()
                    if cont not in ("y", "yes"):
                        print("⛔ Workflow dihentikan.")
                        return

        if wait_sec > 0:
            print(f"    ⏳ Menunggu {wait_sec}s...")
            time.sleep(wait_sec)

    print(f"\n✅ Workflow '{name}' selesai!")

# ═══════════════════════════════════════════════════════════
# SHELL COMMAND GENERATOR
# ═══════════════════════════════════════════════════════════

SHELL_SYSTEM_PROMPT = """Kamu adalah asisten terminal yang membantu user dengan perintah shell.
Jawab dengan SINGKAT dan PADAT. 

Jika user minta command, berikan command yang siap pakai.
Jika command dimulai dengan $, user bisa langsung copy-paste.

KAPAN MENGGUNAKAN FORMAT:
- Untuk command shell: langsung tulis command-nya, diawali dengan $
  Contoh: $ find /var/log -type f -size +1G
- Untuk penjelasan: berikan penjelasan singkat 1-2 kalimat
- Untuk file content: mulai dengan path file di baris pertama
- Jangan pernah kasih markdown code blocks — langsung tulis commandnya"""

def generate_command(prompt: str, config: dict, stdin_data: str = "") -> str:
    full_prompt = prompt
    if stdin_data:
        full_prompt = f"Output dari command sebelumnya:\n```\n{stdin_data[:3000]}\n```\n\nPertanyaan: {prompt}"
    system = SHELL_SYSTEM_PROMPT
    system += "\n\nLingkungan: Linux, shell bash, user ubuntu."
    return ai_chat(full_prompt, system, config)

# ═══════════════════════════════════════════════════════════
# SHELL INTEGRATION — last / explain-last
# ═══════════════════════════════════════════════════════════

def _save_last_output(output: str, command: str = ""):
    """Save last command output for later AI analysis."""
    try:
        LAST_OUTPUT_FILE.write_text(output[:10000])
        if command:
            LAST_CMD_FILE.write_text(command[:500])
    except Exception:
        pass

def get_last_output() -> Tuple[str, str]:
    """Read last saved command output and command."""
    out = ""
    cmd = ""
    try:
        if LAST_OUTPUT_FILE.exists():
            out = LAST_OUTPUT_FILE.read_text()[:5000]
        if LAST_CMD_FILE.exists():
            cmd = LAST_CMD_FILE.read_text()[:200]
    except Exception:
        pass
    return out, cmd

# ═══════════════════════════════════════════════════════════
# COMPLETION GENERATOR
# ═══════════════════════════════════════════════════════════

COMPLETION_BASH = """# OpsTerm Bash Completion
# Add to .bashrc:  source <(ai completion bash)

_opsterm_completions() {
    local cur prev words cword
    _init_completion || return
    local cmds="ssh run servers workflows config history init scp vault last explain-last completion"
    cur="${{words[cword]}}"
    prev="${{words[cword-1]}}"
    case "${{prev}}" in
        ai) mapfile -t COMPREPLY < <(compgen -W "${{cmds}}" -- "${{cur}}"); return 0 ;;
        ssh|--via|-v)
            local servers; servers=$(ai servers list 2>/dev/null | awk 'NR>2 && !/^---/ && !/^Total:/ {{print $1}}')
            mapfile -t COMPREPLY < <(compgen -W "${{servers}}" -- "${{cur}}"); return 0 ;;
        run)
            local workflows; workflows=$(ai workflows list 2>/dev/null | grep '⚡' | awk '{{print $2}}')
            mapfile -t COMPREPLY < <(compgen -W "${{workflows}}" -- "${{cur}}"); return 0 ;;
        servers) mapfile -t COMPREPLY < <(compgen -W "list add edit rm" -- "${{cur}}"); return 0 ;;
        workflows) mapfile -t COMPREPLY < <(compgen -W "list add edit rm" -- "${{cur}}"); return 0 ;;
        config) mapfile -t COMPREPLY < <(compgen -W "list get set" -- "${{cur}}"); return 0 ;;
        vault) mapfile -t COMPREPLY < <(compgen -W "init set get list rm lock" -- "${{cur}}"); return 0 ;;
        scp)
            local servers; servers=$(ai servers list 2>/dev/null | awk 'NR>2 && !/^---/ && !/^Total:/ {{print $1":"}}')
            mapfile -t COMPREPLY < <(compgen -W "${{servers}}" -- "${{cur}}"); return 0 ;;
        completion) mapfile -t COMPREPLY < <(compgen -W "bash zsh" -- "${{cur}}"); return 0 ;;
    esac
    if [[ "${{cword}}" -eq 1 ]]; then
        mapfile -t COMPREPLY < <(compgen -W "${{cmds}}" -- "${{cur}}")
    fi
}
complete -F _opsterm_completions ai
"""

COMPLETION_ZSH = """# OpsTerm Zsh Completion
# Add to .zshrc:  source <(ai completion zsh)

_opsterm() {
    local -a cmds
    cmds=(
        'ssh:SSH ke server tersimpan'
        'run:Jalanin workflow'
        'servers:Manage server list'
        'workflows:Manage workflow list'
        'config:Lihat/set konfigurasi'
        'history:Riwayat command'
        'init:Setup konfigurasi awal'
        'scp:Upload/download file'
        'vault:Encrypted credentials'
        'last:Output command terakhir'
        'explain-last:Explain output pake AI'
        'completion:Generate completion script'
    )
    _arguments -C '1: :->command' '*: :->args'
    case "$state" in
        command) _describe 'command' cmds ;;
        args)
            case "$words[1]" in
                ssh|--via)
                    local servers; servers=(${(f)"$(ai servers list 2>/dev/null | awk 'NR>2 && !/^---/ && !/^Total:/ {print $1}')"})
                    _describe 'server' servers ;;
                run)
                    local workflows; workflows=(${(f)"$(ai workflows list 2>/dev/null | grep '⚡' | awk '{print $2}')"})
                    _describe 'workflow' workflows ;;
                servers) _values 'action' list add edit rm ;;
                workflows) _values 'action' list add edit rm ;;
                config) _values 'action' list get set ;;
                vault) _values 'action' init set get list rm lock ;;
                scp)
                    local servers; servers=(${(f)"$(ai servers list 2>/dev/null | awk 'NR>2 && !/^---/ && !/^Total:/ {print $1":"}')"})
                    _describe 'server' servers ;;
                completion) _values 'shell' bash zsh ;;
            esac ;;
    esac
}
compdef _opsterm ai
"""

# ═══════════════════════════════════════════════════════════
# DISPLAY HELPERS
# ═══════════════════════════════════════════════════════════

def print_server_table(servers: dict):
    if not servers:
        print("📭 Belum ada server tersimpan.")
        return
    header = f"{'NAMA':<20} {'HOST':<22} {'USER':<12} {'PORT':<6} {'PROXY':<15} DESKRIPSI"
    sep = "-" * 100
    print(f"\n{header}\n{sep}")
    for name, s in sorted(servers.items()):
        proxy = s.get("proxy", "") or "—"
        print(f"{name:<20} {s.get('host',''):<22} {s.get('user',''):<12} {s.get('port',22):<6} {proxy:<15} {s.get('desc','')}")

def print_workflow_table(workflows: dict):
    if not workflows:
        print("📭 Belum ada workflow tersimpan.")
        return
    for name, w in sorted(workflows.items()):
        steps = len(w.get("steps", []))
        print(f"  ⚡ {name}")
        print(f"     {w.get('desc', '')} ({steps} step{'s' if steps != 1 else ''})")

# ═══════════════════════════════════════════════════════════
# INTERACTIVE EDITORS
# ═══════════════════════════════════════════════════════════

def interactive_add_server():
    print("== Tambah Server Baru ==")
    name = input("  Nama: ").strip()
    if not name:
        print("❌ Nama wajib diisi."); return
    servers = get_servers()
    if name in servers:
        ov = input(f"⚠️ Server '{name}' sudah ada. Timpa? [y/N] ").strip().lower()
        if ov not in ("y", "yes"): return
    host = input("  Host/IP: ").strip()
    user = input("  User [root]: ").strip() or "root"
    port_str = input("  Port [22]: ").strip()
    port = int(port_str) if port_str else 22
    key = input("  SSH key path [~/.ssh/id_ed25519]: ").strip() or "~/.ssh/id_ed25519"
    desc = input("  Deskripsi: ").strip()
    proxy = input("  Proxy/jump host (nama server): ").strip()
    s = {"host": host, "user": user, "port": port, "key": key, "desc": desc}
    if proxy:
        s["proxy"] = proxy
    servers[name] = s
    save_servers(servers)
    print(f"✅ Server '{name}' ditambahkan!")

def interactive_add_workflow():
    print("== Tambah Workflow Baru ==")
    name = input("  Nama workflow: ").strip()
    if not name:
        print("❌ Nama wajib diisi."); return
    workflows = get_workflows()
    if name in workflows:
        ov = input(f"⚠️ Workflow '{name}' sudah ada. Timpa? [y/N] ").strip().lower()
        if ov not in ("y", "yes"): return
    desc = input("  Deskripsi: ").strip()
    print("  Tambah steps (kosongkan deskripsi untuk selesai):")
    steps = []
    while True:
        print(f"    Step {len(steps)+1}:")
        step_type = input("      Tipe [local/ssh/scp] (local): ").strip().lower() or "local"
        step_desc = input("      Deskripsi: ").strip()
        if not step_desc:
            break
        if step_type == "scp":
            scp_src = input("      Source path: ").strip()
            scp_dst = input("      Dest path: ").strip()
            ssh_target = input("      Server (tujuan): ").strip()
            steps.append({"scp": scp_src, "to": scp_dst, "ssh": ssh_target, "desc": step_desc})
        elif step_type == "ssh":
            ssh_target = input("      Nama server: ").strip()
            step_cmd = input("      Command: ").strip()
            steps.append({"ssh": ssh_target, "command": step_cmd, "desc": step_desc})
        else:
            step_cmd = input("      Command: ").strip()
            steps.append({"command": step_cmd, "desc": step_desc})
    if not steps:
        print("❌ Minimal 1 step."); return
    workflows[name] = {"desc": desc, "steps": steps}
    save_workflows(workflows)
    print(f"✅ Workflow '{name}' ditambahkan! ({len(steps)} steps)")

# ═══════════════════════════════════════════════════════════
# INIT
# ═══════════════════════════════════════════════════════════

EXAMPLE_SERVERS = {
    "vps-utama": {
        "host": "your-server-ip",
        "user": "root",
        "port": 22,
        "key": "~/.ssh/id_ed25519",
        "desc": "Ganti dengan server lu",
    },
}

EXAMPLE_WORKFLOWS = {
    "cek-server": {
        "desc": "Cek status server — uptime, disk, memory, docker",
        "steps": [{
            "ssh": "vps-utama",
            "command": "echo '=== UPTIME ===' && uptime && echo '=== DISK ===' && df -h / && echo '=== MEMORY ===' && free -h",
            "desc": "Cek system health",
        }],
    },
    "deploy-app": {
        "desc": "Git pull + file transfer + restart container",
        "steps": [
            {"scp": "deploy/config.yaml", "to": "/home/ubuntu/config.yaml", "ssh": "vps-utama", "desc": "Upload config"},
            {"ssh": "vps-utama", "command": "cd /home/ubuntu/app && git pull && docker compose restart", "desc": "Pull & restart"},
            {"command": "echo '✅ Deploy selesai!'", "desc": "Done"},
        ],
    },
}

def do_init():
    if not CONFIG_FILE.exists():
        save_yaml(CONFIG_FILE, {
            "ai": {
                "provider": "deepseek",
                "api_url": "https://api.deepseek.com/v1/chat/completions",
                "api_key": "",
                "model": "deepseek-chat",
                "temperature": 0.3,
                "max_tokens": 1024,
            },
            "shell": {
                "confirm_before_exec": True,
                "auto_exec_patterns": ["^ssh ", "^kubectl ", "^docker ", "^cd "],
            },
        })
        print(f"✅ Config created: {CONFIG_FILE}")
    if not SERVERS_FILE.exists():
        save_yaml(SERVERS_FILE, {"servers": EXAMPLE_SERVERS})
        print(f"✅ Servers file created: {SERVERS_FILE}")
        print("   📌 Edit contoh server di file tersebut dengan data lu.")
    if not WORKFLOWS_FILE.exists():
        save_yaml(WORKFLOWS_FILE, {"workflows": EXAMPLE_WORKFLOWS})
        print(f"✅ Workflows file created: {WORKFLOWS_FILE}")
        print("   📌 Edit contoh workflow di file tersebut.")

    print(f"""
📁 Config dir: {CONFIG_DIR}
🔑 Set API key:  export OPSTERM_API_KEY='sk-...'
🔐 Vault:         ai vault init
🔄 Multi-hop:     tambah proxy: di servers.yaml
📁 SCP:           ai scp vps-utama:file.txt .
⚡ Coba:          ai ssh vps-utama
                  ai run cek-server
                  ai how to check disk
""")

# ═══════════════════════════════════════════════════════════
# MAIN CLI
# ═══════════════════════════════════════════════════════════

def main():
    # Check for stdin pipe
    stdin_data = ""
    if not sys.stdin.isatty():
        try:
            stdin_data = sys.stdin.read()
        except Exception:
            pass

    parser = argparse.ArgumentParser(
        prog="ai",
        description="OpsTerm — AI Terminal Assistant. Custom AI provider + servers, workflows, multi-hop, SCP, vault.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            Examples:
              ai how to find large files
              ai ssh vps-utama
              ai ssh internal-server --via bastion
              ai scp file.txt vps-utama:/home/ubuntu/
              ai scp vps-utama:logs/app.log .
              ai run deploy-app
              ai vault set db_password
              docker ps | ai "any errors?"
        """),
    )
    parser.add_argument("args", nargs="*", help="Command or prompt")
    args = parser.parse_args()
    raw_args = args.args
    if not raw_args and not stdin_data:
        parser.print_help()
        return

    subcmd = raw_args[0] if raw_args else ""

    # ── completion ──
    if subcmd == "completion":
        shell = raw_args[1] if len(raw_args) > 1 else "bash"
        if shell == "bash":
            print(COMPLETION_BASH)
        elif shell == "zsh":
            print(COMPLETION_ZSH)
        else:
            print("❌ Shell not supported. Use: bash or zsh")
        return

    # ── init ──
    if subcmd == "init":
        do_init()
        return

    # ── config ──
    elif subcmd == "config":
        cfg = load_config()
        if len(raw_args) == 1:
            print(_dump_yaml(cfg))
        elif raw_args[1] == "list":
            print(_dump_yaml(cfg))
        elif raw_args[1] == "get" and len(raw_args) > 2:
            key = raw_args[2]
            parts = key.split(".")
            val = cfg
            for p in parts:
                val = val.get(p, {}) if isinstance(val, dict) else "❌ Key not found"
            print(val)
        elif raw_args[1] == "set" and len(raw_args) > 3:
            key = raw_args[2]
            val = raw_args[3]
            current = load_yaml(CONFIG_FILE)
            parts = key.split(".")
            d = current
            for p in parts[:-1]:
                d = d.setdefault(p, {})
            d[parts[-1]] = _parse_scalar(val)
            save_yaml(CONFIG_FILE, current)
            print(f"✅ {key} = {val}")
        else:
            print("Usage: ai config [list|get <key>|set <key> <value>]")

    # ── servers ──
    elif subcmd == "servers":
        servers = get_servers()
        if len(raw_args) == 1:
            print_server_table(servers)
            print(f"\n  Total: {len(servers)} server(s)")
            print("  Gunakan: ai servers [list|add|edit|rm]")
        elif raw_args[1] == "list":
            print_server_table(servers)
        elif raw_args[1] == "add":
            interactive_add_server()
        elif raw_args[1] == "edit" and len(raw_args) > 2:
            target = raw_args[2]
            if target not in servers:
                print(f"❌ Server '{target}' tidak ditemukan."); return
            print(f"Edit server '{target}' (kosongkan untuk skip):")
            s = servers[target]
            host = input(f"  Host [{s.get('host','')}]: ").strip() or s.get('host','')
            user = input(f"  User [{s.get('user','')}]: ").strip() or s.get('user','')
            port_str = input(f"  Port [{s.get('port',22)}]: ").strip()
            port = int(port_str) if port_str else s.get('port',22)
            key = input(f"  SSH key [{s.get('key','')}]: ").strip() or s.get('key','')
            desc = input(f"  Deskripsi [{s.get('desc','')}]: ").strip() or s.get('desc','')
            proxy = input(f"  Proxy [{s.get('proxy','')}]: ").strip() or s.get('proxy','')
            servers[target] = {"host": host, "user": user, "port": port, "key": key, "desc": desc}
            if proxy:
                servers[target]["proxy"] = proxy
            save_servers(servers)
            print(f"✅ Server '{target}' diupdate!")
        elif raw_args[1] == "rm" and len(raw_args) > 2:
            target = raw_args[2]
            if target in servers:
                confirm = input(f"Hapus server '{target}'? [y/N] ").strip().lower()
                if confirm in ("y", "yes"):
                    del servers[target]
                    save_servers(servers)
                    print(f"✅ Server '{target}' dihapus.")
            else:
                print(f"❌ Server '{target}' tidak ditemukan.")
        else:
            print("Usage: ai servers [list|add|edit <name>|rm <name>]")

    # ── workflows ──
    elif subcmd == "workflows":
        workflows = get_workflows()
        if len(raw_args) == 1:
            print_workflow_table(workflows)
            print(f"\n  Total: {len(workflows)} workflow(s)")
            print("  Gunakan: ai workflows [list|add|edit|rm]")
        elif raw_args[1] == "list":
            print_workflow_table(workflows)
        elif raw_args[1] == "add":
            interactive_add_workflow()
        elif raw_args[1] == "edit" and len(raw_args) > 2:
            target = raw_args[2]
            if target not in workflows:
                print(f"❌ Workflow '{target}' tidak ditemukan."); return
            print(f"📝 Edit workflow '{target}' — langsung edit filenya:")
            print(f"   {WORKFLOWS_FILE}")
            editor = os.environ.get("EDITOR", "nano")
            subprocess.run([editor, str(WORKFLOWS_FILE)])
        elif raw_args[1] == "rm" and len(raw_args) > 2:
            target = raw_args[2]
            if target in workflows:
                confirm = input(f"Hapus workflow '{target}'? [y/N] ").strip().lower()
                if confirm in ("y", "yes"):
                    workflows = get_workflows()
                    del workflows[target]
                    save_workflows(workflows)
                    print(f"✅ Workflow '{target}' dihapus.")
            else:
                print(f"❌ Workflow '{target}' tidak ditemukan.")
        else:
            print("Usage: ai workflows [list|add|edit <name>|rm <name>]")

    # ── ssh (with --via / multi-hop) ──
    elif subcmd == "ssh" and len(raw_args) > 1:
        server_name = raw_args[1]
        proxy_name = ""
        if "--via" in raw_args:
            idx = raw_args.index("--via")
            if idx + 1 < len(raw_args):
                proxy_name = raw_args[idx + 1]
        elif "-v" in raw_args:
            idx = raw_args.index("-v")
            if idx + 1 < len(raw_args):
                proxy_name = raw_args[idx + 1]

        servers = get_servers()
        cmd = ssh_connect(server_name, servers, proxy_name)
        if cmd:
            via_str = f" via {proxy_name}" if proxy_name else ""
            add_history("ssh", f"ssh {server_name}{via_str}")
            print(f"🔑 Connecting to {server_name}{via_str}...")
            run_ssh(cmd)

    # ── scp ──
    elif subcmd == "scp" and len(raw_args) >= 3:
        source = raw_args[1]
        dest = raw_args[2]
        proxy_name = ""
        if "--via" in raw_args:
            idx = raw_args.index("--via")
            if idx + 1 < len(raw_args):
                proxy_name = raw_args[idx + 1]
        elif "-v" in raw_args:
            idx = raw_args.index("-v")
            if idx + 1 < len(raw_args):
                proxy_name = raw_args[idx + 1]
        servers = get_servers()
        via_str = f" via {proxy_name}" if proxy_name else ""
        add_history("scp", f"{source} → {dest}{via_str}")
        scp_transfer(source, dest, servers, proxy_name)

    # ── vault ──
    elif subcmd == "vault":
        vault = Vault()
        if len(raw_args) == 1:
            print("🔐 OpsTerm Vault — Encrypted Credential Store")
            print("  init   — Buat vault baru")
            print("  set    — Simpan credential (ai vault set <key>)")
            print("  get    — Ambil credential (ai vault get <key>)")
            print("  list   — Lihat semua key")
            print("  rm     — Hapus key")
            print("  lock   — Kunci vault")
            print(f"\n  File: {VAULT_FILE}")
            print("  Env:   OPSTERM_VAULT_PASSWORD")
            return
        action = raw_args[1]
        if action == "init":
            vault.init()
        elif action == "set":
            key = raw_args[2] if len(raw_args) > 2 else ""
            if not key:
                print("Usage: ai vault set <key> [value]")
                print("  (value optional, akan di-prompt jika kosong)")
                return
            value = " ".join(raw_args[3:]) if len(raw_args) > 3 else ""
            vault.set(key, value)
            add_history("vault", f"set {key}")
        elif action == "get":
            key = raw_args[2] if len(raw_args) > 2 else ""
            if not key:
                print("Usage: ai vault get <key>")
                return
            value = vault.get(key)
            if value:
                print(value)
        elif action == "list":
            vault.list_keys()
        elif action == "rm":
            key = raw_args[2] if len(raw_args) > 2 else ""
            if not key:
                print("Usage: ai vault rm <key>")
                return
            vault.rm(key)
        elif action == "lock":
            vault.lock()
        else:
            print(f"❌ Unknown vault action: {action}")

    # ── last ──
    elif subcmd == "last":
        out, cmd = get_last_output()
        if not out and not cmd:
            print("📭 Belum ada output tersimpan.")
            print("   Command terakhir otomatis disimpan oleh zsh plugin.")
            print("   Tanpa plugin: gunakan pipe mode | ai explain")
        else:
            if cmd:
                print(f"💻 Command: {cmd}")
            if out:
                print(f"📄 Output:\n{out[:2000]}")

    # ── explain-last ──
    elif subcmd in ("explain-last", "explain_last"):
        out, cmd = get_last_output()
        if not out and not cmd:
            print("📭 Belum ada output yang bisa di-explain.")
            print("   Jalankan command dulu, atau pipe: cmd | ai explain")
            return
        config = load_config()
        prompt = f"Explain output dari command '{cmd}' ini:\n```\n{out[:3000]}\n```"
        response = generate_command(prompt, config)
        add_history("pipe" if out else "ai", cmd or "(last)", response)
        print(response)

    # ── run ──
    elif subcmd == "run" and len(raw_args) > 1:
        wf_name = raw_args[1]
        config = load_config()
        servers = get_servers()
        workflows = get_workflows()
        add_history("workflow", f"run {wf_name}")
        run_workflow(wf_name, workflows, servers, config)

    # ── history ──
    elif subcmd == "history":
        limit = int(raw_args[1]) if len(raw_args) > 1 and raw_args[1].isdigit() else 20
        show_history(limit)

    # ── AI mode (default) ──
    else:
        prompt = " ".join(raw_args) if raw_args else ""
        if not prompt and stdin_data:
            prompt = "Jelaskan output ini"
        if not prompt:
            print("❌ Masukkan pertanyaan.")
            return

        config = load_config()
        response = generate_command(prompt, config, stdin_data)
        add_history("pipe" if stdin_data else "ai", prompt, response)
        print(response)

        # Auto-exec suggestion
        if config.get("shell", {}).get("confirm_before_exec", True):
            lines = response.strip().split("\n")
            exec_candidates = []
            for line in lines:
                line_s = line.strip()
                if line_s.startswith("$ "):
                    exec_candidates.append(line_s[2:])
            if exec_candidates:
                print()
                for candidate in exec_candidates:
                    resp = input(f"💻 Jalanin: {candidate}? [y/N] ").strip().lower()
                    if resp in ("y", "yes"):
                        result = subprocess.run(candidate, shell=True, capture_output=True)
                        out = result.stdout.decode() + result.stderr.decode()
                        _save_last_output(out, candidate)
                        if out:
                            print(out[:2000])
                        add_history("shell", candidate)
                        # Auto-save for explain-last
                        _save_last_output(out, candidate)

if __name__ == "__main__":
    main()
