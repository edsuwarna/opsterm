EXAMPLE_SERVERS = {
    "vps-utama": {
        "host": "your-server-ip",
        "user": "root",
        "port": 22,
        "key": "~/.ssh/id_ed25519",
        "desc": "Replace with your server",
    },
}

EXAMPLE_WORKFLOWS = {
    "cek-server": {
        "desc": "Cek status server — uptime, disk, memory, docker",
        "steps": [{
            "ssh": "vps-utama",
            "command": "echo '=== UPTIME ===' && uptime && echo '=== DISK ===' && df -h / && echo '=== MEMORY ===' && free -h",
            "desc": "Cek system health",
        }],
    },
    "deploy-app": {
        "desc": "Git pull + file transfer + restart container",
        "steps": [
            {"scp": "deploy/config.yaml", "to": "/home/ubuntu/config.yaml", "ssh": "vps-utama", "desc": "Upload config"},
            {"ssh": "vps-utama", "command": "cd /home/ubuntu/app && git pull && docker compose restart", "desc": "Pull & restart"},
            {"command": "echo '✅ Deploy done!'", "desc": "Done"},
        ],
    },
}

def do_init():
    # 🔒 Ensure secure permissions on existing files and dir
    _set_secure_permissions_on_all()
    os.chmod(str(CONFIG_DIR), 0o700)
    if not CONFIG_FILE.exists():
        save_yaml(CONFIG_FILE, {
            "default_provider": "default",
            "providers": {
                "default": {
                    "api_key": "",
                    "api_url": "https://api.deepseek.com/v1/chat/completions",
                    "model": "deepseek-chat",
                },
            },
            "ai": {
                "temperature": 0.3,
                "max_tokens": 1024,
                "response_style": "concise",
                "system_prompt": "",
            },
            "shell": {
                "confirm_before_exec": True,
                "auto_exec_patterns": ["^ssh ", "^kubectl ", "^docker ", "^cd "],
            },
            "rtk": {
                "enabled": True,
                "auto_detect": True,
                "ultra_compact": False,
            },
        })
        print(f"✅ Config created: {CONFIG_FILE}")
    if not SERVERS_FILE.exists():
        save_yaml(SERVERS_FILE, {"servers": EXAMPLE_SERVERS})
        print(f"✅ Servers file created: {SERVERS_FILE}")
        print("   📌 Edit the example server in that file with your data.")
    if not WORKFLOWS_FILE.exists():
        save_yaml(WORKFLOWS_FILE, {"workflows": EXAMPLE_WORKFLOWS})
        print(f"✅ Workflows file created: {WORKFLOWS_FILE}")
        print("   📌 Edit contoh workflow di file tersebut.")

    print(f"""
📁 Config dir: {CONFIG_DIR}
🔑 Set API key:  opsterm provider add default --api-key 'sk-...'
   Or:           export OPSTERM_API_KEY='sk-...'
🔐 Vault:         opsterm vault init
📁 SCP:           opsterm scp vps-utama:file.txt .
⚡ Coba:          opsterm ssh vps-utama
                  opsterm run cek-server
                  opsterm how to check disk
""")


# ── Ensure config exists (silent auto-init) ─────────────────

def _ensure_config():
    """Silently create config files if they don't exist (auto-init on first run)."""
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    os.chmod(str(CONFIG_DIR), 0o700)
    if not CONFIG_FILE.exists():
        save_yaml(CONFIG_FILE, {
            "default_provider": "default",
            "providers": {
                "default": {
                    "api_key": "",
                    "api_url": "https://api.deepseek.com/v1/chat/completions",
                    "model": "deepseek-chat",
                },
            },
            "ai": {
                "temperature": 0.3,
                "max_tokens": 1024,
                "response_style": "concise",
                "system_prompt": "",
            },
            "shell": {
                "confirm_before_exec": True,
                "auto_exec_patterns": ["^ssh ", "^kubectl ", "^docker ", "^cd "],
            },
            "rtk": {
                "enabled": True,
                "auto_detect": True,
                "ultra_compact": False,
            },
        })
    if not SERVERS_FILE.exists():
        save_yaml(SERVERS_FILE, {"servers": EXAMPLE_SERVERS})
    if not WORKFLOWS_FILE.exists():
        save_yaml(WORKFLOWS_FILE, {"workflows": EXAMPLE_WORKFLOWS})


# ── version check ──────────────────────────────────────────
VERSION_CHECK_INTERVAL = 86400  # 24 jam

def _should_check_version() -> bool:
    """Cek apakah udah waktunya ngecek version (1x per 24 jam)."""
    stamp = CONFIG_DIR / ".version_check"
    if stamp.exists():
        try:
            age = time.time() - stamp.stat().st_mtime
            if age < VERSION_CHECK_INTERVAL:
                return False
        except OSError:
            pass
    return True

def _check_version_startup():
    """Async version check — show notification if update available."""
    if not _should_check_version():
        return
    try:
        req = urllib.request.Request(VERSION_CHECK_URL)
        with urllib.request.urlopen(req, timeout=5) as resp:
            latest = resp.read().decode().strip()
        # Update timestamp regardless
        stamp = CONFIG_DIR / ".version_check"
        stamp.touch()
    except Exception:
        return  # silent fail — don't bother user if offline

    if latest and latest != VERSION:
        latest_ver = _parse_ver(latest)
        current_ver = _parse_ver(VERSION)
        if latest_ver > current_ver:
            print(f"")
            print(f"╭─ ⚡ OpsTerm Update —" + "─" * 35)
            print(f"│  Version {VERSION} → {latest} available!")
            print(f"│  Run: opsterm update")
            print(f"╰" + "─" * 50)


# ── update ─────────────────────────────────────────────────
def cmd_update():
    """Check for updates and self-update."""
    try:
        req = urllib.request.Request(VERSION_CHECK_URL)
        with urllib.request.urlopen(req, timeout=10) as resp:
            latest = resp.read().decode().strip()
    except Exception as e:
        print(f"❌ Update check failed: {e}")
        return

    if latest == VERSION:
        print(f"✅ OpsTerm {VERSION} — already up to date!")
        return

    latest_ver = _parse_ver(latest)
    current_ver = _parse_ver(VERSION)
    if latest_ver <= current_ver:
        print(f"✅ OpsTerm {VERSION} — already up to date!")
        return

    print(f"⚡ Update available: {VERSION} → {latest}")
    try:
        resp = input("  Install update? [Y/n] ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        resp = ""
    if resp not in ("", "y", "yes"):
        print("  Cancelled.")
        return

    script_path = Path(__file__).resolve()
    download_url = OPSTERM_RAW_URL.format(version=latest)

    print(f"  Downloading v{latest}...")
    try:
        dl_req = urllib.request.Request(download_url)
        with urllib.request.urlopen(dl_req, timeout=30) as dl_resp:
            new_content = dl_resp.read()
    except Exception as e:
        print(f"❌ Download failed: {e}")
        return

    # Verify it's valid Python before overwriting
    try:
        compile(new_content, f"opsterm-v{latest}", "exec")
    except SyntaxError as e:
        print(f"❌ Update file corrupted (syntax error): {e}")
        return

    # Backup old version
    backup_path = script_path.with_name(script_path.name + ".bak")
    try:
        import shutil
        shutil.copy2(script_path, backup_path)
    except Exception:
        pass

    # Overwrite
    try:
        script_path.write_bytes(new_content)
        script_path.chmod(0o755)
    except Exception as e:
        print(f"❌ Failed to write update: {e}")
        # Restore backup
        if backup_path.exists():
            shutil.copy2(backup_path, script_path)
        return

    # Cleanup backup
    try:
        backup_path.unlink()
    except Exception:
        pass

    print(f"✅ Updated to v{latest}!")
    print(f"♻️  Restart OpsTerm to use the new version.")


# ═══════════════════════════════════════════════════════════
# DOCTOR — Diagnostics
# ═══════════════════════════════════════════════════════════

def cmd_doctor():
    """Diagnose OpsTerm installation and configuration."""
    print("\n🔍 OpsTerm Doctor — Diagnose installation")
    print("─" * 50)
    all_ok = True

    # 1. Config directory
    print(f"\n  📁 Config dir: {CONFIG_DIR}")
    if CONFIG_DIR.exists():
        mode = oct(CONFIG_DIR.stat().st_mode)[-4:]
        print(f"     ✅ Exists (permissions: {mode})")
    else:
        print(f"     ❌ Not found — run 'opsterm init'")
        all_ok = False

    # 2. Config file
    if CONFIG_FILE.exists():
        print(f"  ⚙️  Config file: ✅ Found")
        cfg = load_config()
        ai_cfg = cfg.get("ai", {})
        default_prov = cfg.get("default_provider", "default")
        providers = cfg.get("providers", {})
        prov_cfg = providers.get(default_prov, ai_cfg)

        api_key = prov_cfg.get("api_key", "") or ai_cfg.get("api_key", "")
        api_url = prov_cfg.get("api_url", ai_cfg.get("api_url", ""))

        if api_key:
            masked = api_key[:6] + "…" + api_key[-4:] if len(api_key) > 12 else "***"
            print(f"  🔑 API key:      ✅ {masked}")
        else:
            print(f"  🔑 API key:      ❌ Not set")
            print(f"     Set with: opsterm provider add <name> --api-key 'sk-...'")
            print(f"     Or: export OPSTERM_API_KEY='sk-...'")
            all_ok = False

        model = prov_cfg.get("model", ai_cfg.get("model", "?"))
        print(f"  🤖 Model:        {model}")
        print(f"  🌐 API URL:      {api_url}")

        # Network check
        if api_url:
            try:
                import urllib.request as _req
                from urllib.parse import urlparse
                parsed = urlparse(api_url)
                base = f"{parsed.scheme}://{parsed.netloc}"
                start = time.time()
                r = _req.Request(base, method="HEAD")
                with _req.urlopen(r, timeout=5) as resp:
                    elapsed = time.time() - start
                    print(f"  🌐 Network:       ✅ Reachable ({elapsed:.1f}s)")
            except Exception as e:
                print(f"  🌐 Network:       ⚠️  {str(e)[:60]}")
    else:
        print(f"  ⚙️  Config file: ❌ Not found — run 'opsterm init'")
        all_ok = False

    # 3. Servers file
    if SERVERS_FILE.exists():
        servers = get_servers()
        print(f"  🖥️  Servers:      ✅ {len(servers)} configured")
    else:
        print(f"  🖥️  Servers:      ⚠️  No servers file (optional)")

    # 4. Version
    print(f"  🏷️  Version:      {VERSION}")
    try:
        req = urllib.request.Request(VERSION_CHECK_URL)
        with urllib.request.urlopen(req, timeout=5) as resp:
            latest = resp.read().decode().strip()
        if latest:
            current_ver = _parse_ver(VERSION)
            latest_ver = _parse_ver(latest)
            if latest_ver > current_ver:
                print(f"     ⚠️  Update available: {latest}")
                print(f"     Run: opsterm update")
            elif latest_ver < current_ver:
                print(f"     ✅ Ahead of latest release ({latest})")
            else:
                print(f"     ✅ Latest")
        else:
            print(f"     ⚠️  Could not check latest version")
    except Exception:
        print(f"     ⚠️  Could not check latest version")

    # 5. PATH check
    bin_dir = os.path.expanduser("~/.local/bin")
    path_dirs = os.environ.get("PATH", "").split(":")
    if bin_dir in path_dirs:
        print(f"  📍 ~/.local/bin:  ✅ In PATH")
    else:
        print(f"  📍 ~/.local/bin:  ⚠️  Not in PATH")
        print(f"     Add to ~/.bashrc: export PATH=\"$HOME/.local/bin:$PATH\"")

    # 6. Script location
    script_path = Path(__file__).resolve()
    script_size = script_path.stat().st_size
    print(f"  📄 Script:       {script_path} ({script_size:,} bytes)")

    print()
    if all_ok:
        print("  ✅ All checks passed!")
    else:
        print("  ⚠️  Some checks failed — see above for details.")
    print()


def cmd_chat(raw_args):
    """Interactive chat REPL — type messages, get AI responses, /exit to quit.
    Use --continue to resume the last session."""
    config = load_config()
    ai_cfg = config["ai"]
    api_key = ai_cfg.get("api_key", "")
    if not api_key:
        print("❌ No API key configured. Add a provider first: opsterm provider add")
        return

    # Check for --continue flag
    resume = "--continue" in raw_args or "-c" in raw_args

    messages = [
        {"role": "system", "content": "You are OpsTerm, an AI terminal assistant. Help the user with commands, technical questions, explanations, and system administration. Be concise and practical."}
    ]

    if resume and CHAT_SESSION_FILE.exists():
        try:
            saved = json.loads(CHAT_SESSION_FILE.read_text())
            saved_msgs = saved.get("messages", [])
            for m in saved_msgs:
                if m.get("role") in ("user", "assistant"):
                    messages.append(m)
            msg_count = len(saved_msgs)
            print(f"💬 Resumed previous session ({msg_count} messages)")
        except Exception:
            pass

    provider_name = config.get("default_provider", "default")
    print(f"💬 Opsterm Chat — /exit to quit, /clear to reset")
    print(f"   {provider_name} · {ai_cfg.get('model', '?')}")
    print()

    while True:
        try:
            prompt = input("  You: ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            break
        if not prompt:
            continue
        if prompt.lower() in ("/exit", "/quit", "/q"):
            break
        if prompt.lower() == "/clear":
            messages = [messages[0]]
            print("  🧹 Conversation reset.")
            continue
        if prompt.startswith("/"):
            print(f"  ❌ Unknown command: {prompt}")
            continue

        messages.append({"role": "user", "content": prompt})
        payload = {
            "model": ai_cfg.get("model", "deepseek-chat"),
            "messages": messages,
            "temperature": ai_cfg.get("temperature", 0.3),
            "max_tokens": ai_cfg.get("max_tokens", 2048),
            "stream": False,
        }
        stop_spinner = threading.Event()
        spinner_started = False
        spinner_thread = threading.Thread(
            target=_loading_spinner, args=(stop_spinner, "AI"), daemon=True
        )
        if sys.stdout.isatty():
            spinner_thread.start()
            spinner_started = True
        try:
            req = urllib.request.Request(
                ai_cfg["api_url"],
                data=json.dumps(payload).encode("utf-8"),
                headers={
                    "Content-Type": "application/json",
                    "Authorization": f"Bearer {api_key}",
                    "User-Agent": "Mozilla/5.0",
                },
                method="POST",
            )
            with urllib.request.urlopen(req, timeout=60) as resp:
                result = json.loads(resp.read().decode("utf-8"))
            if spinner_started:
                stop_spinner.set()
                spinner_thread.join(timeout=1)
            reply = result["choices"][0]["message"]["content"].strip()
            messages.append({"role": "assistant", "content": reply})
            print(f"\n  🤖 {reply}\n")
            add_history("chat", prompt, reply)
        except urllib.error.HTTPError as e:
            if spinner_started:
                stop_spinner.set()
                spinner_thread.join(timeout=1)
            body = e.read().decode("utf-8", errors="replace")
            print(f"\n  ❌ HTTP {e.code}: {body[:300]}\n")
        except Exception as e:
            if spinner_started:
                stop_spinner.set()
                spinner_thread.join(timeout=1)
            print(f"\n  ❌ Error: {e}\n")

    # Save session on exit
    try:
        CHAT_SESSION_FILE.write_text(json.dumps({"messages": messages[1:]}))
    except Exception:
        pass


CHAT_SESSION_FILE = CONFIG_DIR / "chat_session.json"


# ═══════════════════════════════════════════════════════════
# NEW FEATURES — v0.6.0
# ═══════════════════════════════════════════════════════════

def cmd_validate_config() -> bool:
    """Validate all YAML config files. Returns True if all OK."""
    all_ok = True
    files = [
        ("Config", CONFIG_FILE, False),
        ("Servers", SERVERS_FILE, True),
        ("Workflows", WORKFLOWS_FILE, True),
    ]
    for name, path, optional in files:
        if not path.exists():
            if optional:
                print(f"  ⚠️  {name}: {path.name} not found (optional)")
            else:
                print(f"  ❌ {name}: {path.name} not found — run 'opsterm init'")
                all_ok = False
            continue
        try:
            text = path.read_text("utf-8")
            parsed = _parse_yaml(text)
            if not isinstance(parsed, dict):
                print(f"  ❌ {name}: {path.name} — root must be a mapping")
                all_ok = False
                continue
            # Specific validations
            if name == "Config":
                providers = parsed.get("providers", {})
                for pname, p in providers.items():
                    if not isinstance(p, dict):
                        print(f"  ⚠️  Config: provider '{pname}' should be a mapping")
                        continue
                    if p.get("api_url") and "/chat/completions" not in str(p.get("api_url", "")):
                        print(f"  ⚠️  Config: provider '{pname}' api_url seems wrong (missing /chat/completions)")
                default = parsed.get("default_provider", "")
                if default and default not in providers:
                    print(f"  ⚠️  Config: default_provider '{default}' not in configured providers")
            if name == "Servers":
                servers = parsed.get("servers", {})
                for sname, s in servers.items():
                    if not isinstance(s, dict):
                        continue
                    if not s.get("host"):
                        print(f"  ⚠️  Servers: '{sname}' has no host")
                    port = s.get("port", 22)
                    if not isinstance(port, (int, float)) or port < 1 or port > 65535:
                        print(f"  ⚠️  Servers: '{sname}' has invalid port {port}")
            if name == "Workflows":
                workflows = parsed.get("workflows", {})
                for wname, w in workflows.items():
                    if not isinstance(w, dict) or "steps" not in w:
                        print(f"  ⚠️  Workflows: '{wname}' has no steps")
                        continue
                    if not w["steps"]:
                        print(f"  ⚠️  Workflows: '{wname}' has empty steps")
            print(f"  ✅ {name}: {path.name} — valid")
        except Exception as e:
            print(f"  ❌ {name}: {path.name} — parse error: {e}")
            all_ok = False
    return all_ok


def cmd_ssh_all(command: str, servers: dict):
    """Run a command on all configured servers."""
    if not servers:
        print("📭 No servers configured.")
        return
    results = {}
    for name, s in sorted(servers.items()):
        host = s.get("host", "")
        user = s.get("user", "root")
        port = s.get("port", 22)
        key = s.get("key", "")
        proxy_str = ""
        if s.get("proxy"):
            ps = _server_lookup(s["proxy"], servers)
            if ps:
                proxy_str = _resolve_proxy(s["proxy"], servers)
        print(f"  🔑 [{name}] ({user}@{host}:{port})...", end=" ", flush=True)
        cmd = ["ssh", "-o", "ConnectTimeout=5", "-o", "StrictHostKeyChecking=no",
               "-o", "BatchMode=yes"]
        if key:
            cmd.extend(["-i", os.path.expanduser(key)])
        if port != 22:
            cmd.extend(["-p", str(port)])
        if proxy_str:
            cmd.extend(["-J", proxy_str])
        cmd.append(f"{user}@{host}")
        cmd.append(command)
        try:
            result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
            if result.returncode == 0:
                print("✅")
                results[name] = ("ok", result.stdout.strip()[:500])
            else:
                err = result.stderr.strip()[:100]
                print(f"❌ {err}")
                results[name] = ("fail", err)
        except subprocess.TimeoutExpired:
            print("⏰ Timeout")
            results[name] = ("timeout", "")
        except Exception as e:
            print(f"❌ {e}")
            results[name] = ("error", str(e)[:100])

    # Summary
    ok_count = sum(1 for v in results.values() if v[0] == "ok")
    print(f"\n  📊 Results: {ok_count}/{len(servers)} OK")
    for name, (status, out) in results.items():
        icon = "✅" if status == "ok" else "❌"
        print(f"    {icon} {name}: {out[:120]}")
    print()


def cmd_import_ssh_config(servers: dict) -> dict:
    """Import servers from ~/.ssh/config. Returns updated servers dict."""
    ssh_config_path = Path.home() / ".ssh" / "config"
    if not ssh_config_path.exists():
        print(f"❌ {ssh_config_path} not found.")
        return servers

    text = ssh_config_path.read_text("utf-8")
    imported = 0
    skipped = 0
    current_host = ""
    current = {}

    for line in text.split("\n"):
        stripped = line.strip()
        if not stripped or stripped.startswith("#"):
            continue
        if stripped.lower().startswith("host "):
            # Save previous
            if current_host and current_host != "*":
                key = current_host
                if key not in servers:
                    servers[key] = current
                    imported += 1
                else:
                    skipped += 1
            # Start new
            parts = stripped.split()
            current_host = parts[1] if len(parts) > 1 else ""
            current = {"user": "root", "port": 22, "key": "~/.ssh/id_ed25519"}
            if "*" in current_host or "?" in current_host:
                current_host = ""
        elif current_host and current_host != "*":
            if stripped.lower().startswith("hostname "):
                current["host"] = stripped.split(None, 1)[1]
            elif stripped.lower().startswith("user "):
                current["user"] = stripped.split(None, 1)[1]
            elif stripped.lower().startswith("port "):
                try:
                    current["port"] = int(stripped.split(None, 1)[1])
                except ValueError:
                    pass
            elif stripped.lower().startswith("identityfile "):
                path = stripped.split(None, 1)[1]
                path = path.replace("~", str(Path.home()))
                for p in path.split():
                    expanded = os.path.expanduser(p)
                    if os.path.exists(expanded):
                        current["key"] = p
                        break
                else:
                    current["key"] = path.split()[0] if path.split() else "~/.ssh/id_ed25519"
            elif stripped.lower().startswith("proxyjump "):
                current["proxy"] = stripped.split(None, 1)[1]

    # Last host save
    if current_host and current_host != "*" and current.get("host"):
        if current_host not in servers:
            servers[current_host] = current
            imported += 1
        else:
            skipped += 1

    print(f"  ✅ Imported {imported} server(s) from ~/.ssh/config", end="")
    if skipped:
        print(f" ({skipped} skipped — already exist)")
    else:
        print()
    return servers


def cmd_workflow_init():
    """Initialize sample workflows file if not exists."""
    if WORKFLOWS_FILE.exists():
        overwrite = input(f"⚠️  {WORKFLOWS_FILE} already exists. Overwrite? [y/N] ").strip().lower()
        if overwrite not in ("y", "yes"):
            print("  Cancelled.")
            return
    save_yaml(WORKFLOWS_FILE, {"workflows": EXAMPLE_WORKFLOWS})
    print(f"✅ Sample workflows created: {WORKFLOWS_FILE}")
    print(f"   Run: opsterm workflows list")
    print(f"   Run: opsterm run cek-server")


def cmd_export(path: str = ""):
    """Export config to a tar.gz file."""
    import shutil
    import tarfile
    if not path:
        path = f"opsterm-export-{time.strftime('%Y%m%d-%H%M%S')}.tar.gz"
    export_path = Path(path)
    with tarfile.open(str(export_path), "w:gz") as tar:
        for name, filepath in [
            ("config.yaml", CONFIG_FILE),
            ("servers.yaml", SERVERS_FILE),
            ("workflows.yaml", WORKFLOWS_FILE),
        ]:
            if filepath.exists():
                tar.add(str(filepath), arcname=name)
        cfg = load_yaml(CONFIG_FILE)
        export_cfg = {"export_version": VERSION, "exported_at": time.strftime("%Y-%m-%d %H:%M:%S")}
        providers = cfg.get("providers", {})
        export_providers = {}
        for pname, p in providers.items():
            ep = dict(p)
            if "api_key" in ep and ep["api_key"]:
                k = ep["api_key"]
                ep["api_key"] = f"__MASKED__:{k[:6]}...{k[-4:]}"
            export_providers[pname] = ep
        export_cfg["providers"] = export_providers
        export_cfg["default_provider"] = cfg.get("default_provider", "")
        export_cfg["ai_settings"] = {
            "temperature": cfg.get("ai", {}).get("temperature", 0.3),
            "max_tokens": cfg.get("ai", {}).get("max_tokens", 1024),
            "response_style": cfg.get("ai", {}).get("response_style", "concise"),
        }
        import json as _json
        meta_bytes = _json.dumps(export_cfg, indent=2).encode()
        from io import BytesIO
        info = tarfile.TarInfo(name="export.json")
        info.size = len(meta_bytes)
        tar.addfile(info, BytesIO(meta_bytes))
    print(f"✅ Config exported to: {export_path.resolve()}")
    print(f"   API keys are MASKED — re-add with: opsterm provider add <name> --api-key '...'")


def cmd_import(path: str):
    """Import config from a tar.gz file."""
    import tarfile
    import json as _json
    import_path = Path(path)
    if not import_path.exists():
        print(f"❌ File not found: {path}")
        return
    extracted = {}
    try:
        with tarfile.open(str(import_path), "r:gz") as tar:
            for member in tar.getmembers():
                if member.isfile():
                    f = tar.extractfile(member)
                    if f:
                        extracted[member.name] = f.read().decode("utf-8")
    except Exception as e:
        print(f"❌ Failed to read export: {e}")
        return

    meta = {}
    if "export.json" in extracted:
        try:
            meta = _json.loads(extracted["export.json"])
        except Exception:
            pass

    print(f"  📦 Export version: {meta.get('export_version', '?')}")
    print(f"  📅 Exported: {meta.get('exported_at', '?')}")
    prov_count = len(meta.get("providers", {}))
    print(f"  🔑 Providers: {prov_count} (keys masked — need re-entry)")

    confirmed = input("  Restore config files? Existing files will be backed up. [y/N] ").strip().lower()
    if confirmed not in ("y", "yes"):
        print("  Cancelled.")
        return

    import shutil
    for name, filepath in [
        ("config.yaml", CONFIG_FILE),
        ("servers.yaml", SERVERS_FILE),
        ("workflows.yaml", WORKFLOWS_FILE),
    ]:
        if name in extracted:
            if filepath.exists():
                backup = filepath.with_suffix(filepath.suffix + ".bak")
                shutil.copy2(str(filepath), str(backup))
                print(f"  💾 Backed up {filepath.name} → {backup.name}")
            filepath.write_text(extracted[name])
            print(f"  ✅ Restored {filepath.name}")

    print("⚠️  API keys need to be re-entered for each provider.")
    for pname in meta.get("providers", {}):
        print(f"     opsterm provider add {pname} --api-key '...'")


def cmd_reset():
    """Reset config to defaults — backup and recreate."""
    import shutil
    print("⚠️  This will reset all OpsTerm configuration.")
    resp = input("  This CANNOT be undone. Are you sure? [y/N] ").strip().lower()
    if resp not in ("y", "yes"):
        print("  Cancelled.")
        return
    resp2 = input("  Backup existing config first? [Y/n] ").strip().lower()
    backup_first = resp2 not in ("n", "no")

    if backup_first and CONFIG_DIR.exists():
        backup_dir = CONFIG_DIR.with_name(CONFIG_DIR.name + f"-bak-{time.strftime('%Y%m%d-%H%M%S')}")
        shutil.copytree(str(CONFIG_DIR), str(backup_dir))
        print(f"  💾 Backed up → {backup_dir}")

    if CONFIG_DIR.exists():
        import shutil as _sh
        for item in CONFIG_DIR.iterdir():
            if item.is_file():
                item.unlink()
        print(f"  🧹 Cleared {CONFIG_DIR}")
    do_init()
    print("✅ Config reset complete!")
    print("   Run: opsterm provider add default --api-key 'sk-...'")


