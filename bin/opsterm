#!/usr/bin/env python3
"""
OpsTerm — AI Terminal Assistant
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
Zero-dependency CLI tool: custom AI provider + saved servers, workflows,
multi-hop SSH, SCP, vault, and shell integration.

Usage:
  opsterm <prompt>              Ask AI anything (default mode)
  opsterm ssh <server> [--via <proxy>]   SSH ke server (via jump host opsional)
  opsterm scp <src> <dst>       Upload/download file via server
  opsterm run <workflow>        Jalanin multi-step workflow
  opsterm servers               Manage server list
  opsterm workflows             Manage workflow list
  opsterm config                Manage config
  opsterm provider              Manage AI providers — smart add with auto-detect + model list
  opsterm vault                 Encrypted credentials
  opsterm last                  View last command output
  opsterm explain-last          Explain last output with AI
  opsterm history               Command history
  opsterm init                  Initialize config
  opsterm update                Check & install update
  opsterm completion bash|zsh   Generate completion script
  <cmd> | opsterm <prompt>      Pipe mode
"""

