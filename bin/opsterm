('active');\n  });\n});\n\n// ── Toast ──\nlet toastTimer;\nfunction showToast(msg, type = '') {\n  const t = document.getElementById('toast');\n  t.textContent = msg; t.className = 'toast show ' + type;\n  clearTimeout(toastTimer);\n  toastTimer = setTimeout(() => t.classList.remove('show'), 3500);\n}\n\n// ── Modal ──\nlet modalCallback = null;\nfunction showModal(title, bodyHtml, onConfirm) {\n  document.getElementById('modal-title').textContent = title;\n  document.getElementById('modal-body').innerHTML = bodyHtml;\n  document.getElementById('modal-overlay').classList.add('show');\n  modalCallback = onConfirm;\n}\nfunction closeModal() {\n  document.getElementById('modal-overlay').classList.remove('show');\n  modalCallback = null;\n}\ndocument.getElementById('modal-confirm').addEventListener('click', () => {\n  if (modalCallback) modalCallback();\n  closeModal();\n});\ndocument.getElementById('modal-overlay').addEventListener('click', (e) => {\n  if (e.target === e.currentTarget) closeModal();\n});\n\n// ── API helpers ──\nasync function api(method, path, body) {\n  const opts = { method, headers: {} };\n  if (body) { opts.headers['Content-Type'] = 'application/json'; opts.body = JSON.stringify(body); }\n  const r = await fetch(API + path, opts);\n  if (!r.ok) { const e = await r.json().catch(()=>({})); throw new Error(e.error || r.statusText); }\n  return r.json();\n}\n\n// ── Load Data ──\nasync function loadAll() {\n  try {\n    const [status, servers, workflows, providers, config] = await Promise.all([\n      api('GET', '/status'), api('GET', '/servers'),\n      api('GET', '/workflows'), api('GET', '/providers'), api('GET', '/config')\n    ]);\n    document.getElementById('version').textContent = status.version || '';\n    document.getElementById('status-badge').textContent =\n      `🟢 ${status.servers_count || 0} servers · ${status.workflows_count || 0} workflows · ${status.providers_count || 0} providers`;\n    renderServers(servers.servers || {});\n    renderWorkflows(workflows.workflows || {});\n    renderProviders(providers.providers || {}, providers.default_provider || '');\n    renderConfig(config.config || {});\n  } catch(e) {\n    document.getElementById('status-badge').textContent = '🔴 connection error';\n    showToast('Failed to connect: ' + e.message, 'error');\n  }\n}\n\n// ═════════════════════════════════════════════════\n// SERVERS\n// ═════════════════════════════════════════════════\nfunction renderServers(servers) {\n  const names = Object.keys(servers);\n  document.getElementById('server-count').textContent = names.length;\n  const el = document.getElementById('server-list');\n  if (!names.length) {\n    el.innerHTML = '<div class=\"empty\"><p>No servers configured</p><button class=\"btn btn-primary\" onclick=\"showAddServer()\">+ Add Server</button></div>';\n    return;\n  }\n  el.innerHTML = `<table>\n    <thead><tr><th>Name</th><th>Host</th><th>User</th><th>Port</th><th>Proxy</th><th></th></tr></thead>\n    <tbody>${names.map(n => {\n      const s = servers[n] || {};\n      return `<tr>\n        <td><strong>${esc(n)}</strong>${s.desc ? '<br><span class=\"hint\">'+esc(s.desc)+'</span>' : ''}</td>\n        <td class=\"mono\">${esc(s.host||'-')}</td>\n        <td>${esc(s.user||'root')}</td>\n        <td>${s.port||22}</td>\n        <td>${s.proxy ? esc(s.proxy) : '<span style=\"color:var(--muted)\">—</span>'}</td>\n        <td><div class=\"actions\">\n          <button class=\"btn btn-sm\" onclick=\"editServer('${escAttr(n)}')\">Edit</button>\n          <button class=\"btn btn-sm btn-danger\" onclick=\"deleteServer('${escAttr(n)}')\">Del</button>\n        </div></td>\n      </tr>`;\n    }).join('')}</tbody>\n  </table>`;\n}\n\nfunction showAddServer() { showServerForm('Add Server', {}); }\nfunction editServer(name) {\n  api('GET', '/servers').then(d => {\n    const s = (d.servers||{})[name];\n    if (s) showServerForm('Edit Server: ' + name, s, name);\n  });\n}\n\nfunction showServerForm(title, data, editName) {\n  showModal(title, `\n    <div class=\"form-group\"><label>Name</label><input id=\"f-name\" value=\"${esc(editName||'')}\" ${editName?'readonly style=\"opacity:0.6\"':''}></div>\n    <div class=\"form-group\"><label>Host</label><input id=\"f-host\" value=\"${esc(data.host||'')}\"></div>\n    <div class=\"form-group\"><label>User</label><input id=\"f-user\" value=\"${esc(data.user||'root')}\"></div>\n    <div class=\"form-group\"><label>Port</label><input id=\"f-port\" value=\"${data.port||22}\"></div>\n    <div class=\"form-group\"><label>SSH Key (optional)</label><input id=\"f-key\" value=\"${esc(data.key||'')}\" placeholder=\"~/.ssh/id_ed25519\"></div>\n    <div class=\"form-group\"><label>Proxy/Jump Host (optional)</label><input id=\"f-proxy\" value=\"${esc(data.proxy||'')}\"></div>\n    <div class=\"form-group\"><label>Description (optional)</label><input id=\"f-desc\" value=\"${esc(data.desc||'')}\"></div>\n  `, async () => {\n    const name = document.getElementById('f-name').value.trim();\n    const host = document.getElementById('f-host').value.trim();\n    if (!name || !host) { showToast('Name and host required', 'error'); return; }\n    const body = {\n      host, user: document.getElementById('f-user').value.trim() || 'root',\n      port: parseInt(document.getElementById('f-port').value) || 22,\n      key: document.getElementById('f-key').value.trim(),\n      proxy: document.getElementById('f-proxy').value.trim(),\n      desc: document.getElementById('f-desc').value.trim(),\n    };\n    if (editName) {\n      await api('PUT', '/servers/' + encodeURIComponent(editName), body);\n      showToast('✅ Server updated', 'success');\n    } else {\n      await api('POST', '/servers', { name, ...body });\n      showToast('✅ Server added', 'success');\n    }\n    loadAll();\n  });\n}\n\nasync function deleteServer(name) {\n  showModal('Delete Server', `<p>Delete server <strong>${esc(name)}</strong>? This cannot be undone.</p>`, async () => {\n    await api('DELETE', '/servers/' + encodeURIComponent(name));\n    showToast('🗑️ Server deleted', 'success');\n    loadAll();\n  });\n}\n\n// ═════════════════════════════════════════════════\n// WORKFLOWS\n// ═════════════════════════════════════════════════\nfunction renderWorkflows(workflows) {\n  const names = Object.keys(workflows);\n  document.getElementById('wf-count').textContent = names.length;\n  const el = document.getElementById('workflow-list');\n  if (!names.length) {\n    el.innerHTML = '<div class=\"empty\"><p>No workflows yet</p><button class=\"btn btn-primary\" onclick=\"showAddWorkflow()\">+ Add Workflow</button></div>';\n    return;\n  }\n  el.innerHTML = names.map(n => {\n    const w = workflows[n] || {};\n    const steps = w.steps || [];\n    const stepText = steps.map(s => {\n      if (s.command) return `<code>${esc(s.command)}</code>`;\n      if (s.ssh) return `<code>ssh ${esc(s.ssh)}: ${esc(s.command||'')}</code>`;\n      if (s.local) return `<code>local: ${esc(s.local)}</code>`;\n      return '';\n    }).join(' → ');\n    return `<div class=\"card\" style=\"margin-bottom:8px\">\n      <div style=\"display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:8px\">\n        <div>\n          <strong>${esc(n)}</strong>\n          <div class=\"wf-steps\">${stepText || '<span style=\"color:var(--muted)\">no steps</span>'}</div>\n        </div>\n        <div class=\"actions\" style=\"gap:4px\">\n          <button class=\"btn btn-sm\" onclick=\"editWorkflow('${escAttr(n)}')\">Edit</button>\n          <button class=\"btn btn-sm btn-success\" onclick=\"runWorkflow('${escAttr(n)}', this)\">▶ Run</button>\n          <button class=\"btn btn-sm btn-danger\" onclick=\"deleteWorkflow('${escAttr(n)}')\">Del</button>\n        </div>\n      </div>\n      <div class=\"output-box\" id=\"output-${escAttr(n)}\"></div>\n    </div>`;\n  }).join('');\n}\n\nasync function runWorkflow(name, btn) {\n  const outBox = document.getElementById('output-' + name);\n  outBox.classList.add('show');\n  outBox.textContent = '⏳ Running...';\n  btn.disabled = true;\n  btn.textContent = '⏳';\n  try {\n    const r = await api('POST', '/workflows/run/' + encodeURIComponent(name));\n    outBox.textContent = r.output || '✅ Done (no output)';\n    showToast('✅ Workflow complete', 'success');\n  } catch(e) {\n    outBox.textContent = '❌ Error: ' + e.message;\n    showToast('❌ Workflow failed', 'error');\n  }\n  btn.disabled = false;\n  btn.textContent = '▶ Run';\n}\n\nfunction showAddWorkflow() {\n  showModal('Add Workflow', `\n    <div class=\"form-group\"><label>Name</label><input id=\"wf-name\" placeholder=\"my-workflow\"></div>\n    <div class=\"form-group\"><label>Steps (YAML)</label>\n      <textarea id=\"wf-steps\" placeholder=\"steps:&#10;  - local: echo hello&#10;  - command: apt update&#10;  - ssh: myserver&#10;    command: docker ps\"></textarea>\n    </div>\n    <p class=\"hint\">Define steps as YAML. Each step: <code>command</code>, <code>local</code>, or <code>ssh: server → command</code></p>\n  `, async () => {\n    const name = document.getElementById('wf-name').value.trim();\n    if (!name) { showToast('Name required', 'error'); return; }\n    const stepsText = document.getElementById('wf-steps').value.trim();\n    let workflow = { steps: [] };\n    if (stepsText) {\n      try {\n        const parsed = parseYamlSteps(stepsText);\n        workflow = parsed;\n      } catch(e) {\n        showToast('Invalid YAML: ' + e.message, 'error');\n        return;\n      }\n    }\n    await api('POST', '/workflows', { name, workflow });\n    showToast('✅ Workflow added', 'success');\n    loadAll();\n  });\n}\n\nfunction editWorkflow(name) {\n  api('GET', '/workflows').then(d => {\n    const w = (d.workflows||{})[name];\n    if (!w) return;\n    const stepsYaml = (w.steps || []).map(s => {\n      if (s.command) return '  - command: ' + s.command;\n      if (s.local) return '  - local: ' + s.local;\n      if (s.ssh) return '  - ssh: ' + s.ssh + '\\n    command: ' + (s.command||'');\n      return '  - ' + JSON.stringify(s);\n    }).join('\\n');\n    showModal('Edit Workflow: ' + name, `\n      <div class=\"form-group\"><label>Steps (YAML)</label>\n        <textarea id=\"wf-steps\" style=\"min-height:120px\">steps:\\n${stepsYaml}</textarea>\n      </div>\n      <p class=\"hint\">Edit YAML steps. Remove all text for an empty workflow.</p>\n    `, async () => {\n      const stepsText = document.getElementById('wf-steps').value.trim();\n      let workflow = { steps: [] };\n      if (stepsText) {\n        try {\n          workflow = parseYamlSteps(stepsText);\n        } catch(e) {\n          showToast('Invalid YAML: ' + e.message, 'error');\n          return;\n        }\n      }\n      await api('PUT', '/workflows/' + encodeURIComponent(name), { workflow });\n      showToast('✅ Workflow updated', 'success');\n      loadAll();\n    });\n  });\n}\n\nasync function deleteWorkflow(name) {\n  showModal('Delete Workflow', `<p>Delete workflow <strong>${esc(name)}</strong>?</p>`, async () => {\n    await api('DELETE', '/workflows/' + encodeURIComponent(name));\n    showToast('🗑️ Workflow deleted', 'success');\n    loadAll();\n  });\n}\n\n// Simple YAML steps parser (handles our limited subset)\nfunction parseYamlSteps(text) {\n  const lines = text.split('\\n');\n  const steps = [];\n  let currentStep = null;\n  const stepStart = /^\\s*-\\s+(command|local|ssh):\\s*(.*)$/;\n  const cmdCont = /^\\s+command:\\s*(.*)$/;\n  for (const line of lines) {\n    const m1 = line.match(stepStart);\n    if (m1) {\n      if (currentStep) steps.push(currentStep);\n      currentStep = {};\n      if (m1[1] === 'ssh') {\n        currentStep.ssh = m1[2].trim();\n      } else {\n        currentStep[m1[1]] = m1[2].trim();\n      }\n    } else {\n      const m2 = line.match(cmdCont);\n      if (m2 && currentStep) {\n        currentStep.command = m2[1].trim();\n      }\n    }\n  }\n  if (currentStep) steps.push(currentStep);\n  if (!steps.length && text.trim()) {\n    throw new Error('Could not parse steps. Format: each line starting with - command:, - local:, or - ssh:');\n  }\n  return { steps };\n}\n\n// ═════════════════════════════════════════════════\n// PROVIDERS\n// ═════════════════════════════════════════════════\nfunction renderProviders(providers, defaultProv) {\n  const names = Object.keys(providers);\n  document.getElementById('prov-count').textContent = names.length;\n  const el = document.getElementById('provider-list');\n  if (!names.length) {\n    el.innerHTML = '<div class=\"empty\"><p>No AI providers configured</p><button class=\"btn btn-primary\" onclick=\"showAddProvider()\">+ Add Provider</button></div>';\n    return;\n  }\n  el.innerHTML = `<table>\n    <thead><tr><th>Name</th><th>API URL</th><th>Model</th><th>Key</th><th></th></tr></thead>\n    <tbody>${names.map(n => {\n      const p = providers[n] || {};\n      const isDefault = n === defaultProv;\n      return `<tr>\n        <td><strong>${esc(n)}</strong>${isDefault ? ' <span class=\"default-badge\">⭐ default</span>' : ''}</td>\n        <td class=\"mono\" style=\"max-width:280px;word-break:break-all\">${esc(p.api_url||'—')}</td>\n        <td class=\"mono\">${esc(p.model||'—')}</td>\n        <td class=\"mono\">${esc(p.api_key_masked||'—')}</td>\n        <td><div class=\"actions\" style=\"gap:2px\">\n          ${!isDefault ? `<button class=\"btn btn-sm btn-success\" onclick=\"setDefaultProvider('${escAttr(n)}')\">⭐</button>` : ''}\n          <button class=\"btn btn-sm\" onclick=\"testProvider('${escAttr(n)}')\">🧪 Test</button>\n          <button class=\"btn btn-sm\" onclick=\"editProvider('${escAttr(n)}')\">Edit</button>\n          <button class=\"btn btn-sm btn-danger\" onclick=\"deleteProvider('${escAttr(n)}')\">Del</button>\n        </div></td>\n      </tr>`;\n    }).join('')}</tbody>\n  </table>`;\n}\n\nfunction showAddProvider() { showProviderForm('Add Provider', {}); }\nfunction editProvider(name) {\n  api('GET', '/providers').then(d => {\n    const p = (d.providers||{})[name];\n    if (p) showProviderForm('Edit Provider: ' + name, p, name);\n  });\n}\n\nfunction showProviderForm(title, data, editName) {\n  showModal(title, `\n    <div class=\"form-group\"><label>Name</label><input id=\"p-name\" value=\"${esc(editName||'')}\" ${editName?'readonly style=\"opacity:0.6\"':''} placeholder=\"my-provider\"></div>\n    <div class=\"form-group\"><label>API URL</label><input id=\"p-url\" value=\"${esc(data.api_url||'')}\" placeholder=\"https://api.openai.com/v1\"></div>\n    <div class=\"form-group\"><label>Model</label><input id=\"p-model\" value=\"${esc(data.model||'')}\" placeholder=\"gpt-4o\"></div>\n    <div class=\"form-group\"><label>API Key</label><input id=\"p-key\" type=\"password\" value=\"${esc(editName ? data.api_key_masked||'' : '')}\" placeholder=\"${editName ? 'leave blank to keep current' : 'sk-...'}\"></div>\n    <p class=\"hint\">Test the provider after saving from the provider list.</p>\n  `, async () => {\n    const name = document.getElementById('p-name').value.trim();\n    const apiUrl = document.getElementById('p-url').value.trim();\n    if (!name || !apiUrl) { showToast('Name and API URL required', 'error'); return; }\n    const model = document.getElementById('p-model').value.trim();\n    const apiKey = document.getElementById('p-key').value.trim();\n    if (!editName && !apiKey) { showToast('API Key required for new provider', 'error'); return; }\n    const body = { api_url: apiUrl, model, api_key: apiKey };\n    if (editName) {\n      await api('PUT', '/providers/' + encodeURIComponent(editName), body);\n      showToast('✅ Provider updated', 'success');\n    } else {\n      await api('POST', '/providers', { name, ...body });\n      showToast('✅ Provider added', 'success');\n    }\n    loadAll();\n  });\n}\n\nasync function deleteProvider(name) {\n  showModal('Delete Provider', `<p>Delete provider <strong>${esc(name)}</strong>?</p>`, async () => {\n    await api('DELETE', '/providers/' + encodeURIComponent(name));\n    showToast('🗑️ Provider deleted', 'success');\n    loadAll();\n  });\n}\n\nasync function setDefaultProvider(name) {\n  try {\n    await api('PUT', '/providers/' + encodeURIComponent(name) + '/default');\n    showToast('⭐ Default provider set to ' + name, 'success');\n    loadAll();\n  } catch(e) {\n    showToast('❌ ' + e.message, 'error');\n  }\n}\n\nasync function testProvider(name) {\n  showToast('🧪 Testing ' + name + '...');\n  try {\n    const r = await api('POST', '/providers/test/' + encodeURIComponent(name));\n    if (r.ok) {\n      showToast('✅ ' + name + ' connected!', 'success');\n    } else {\n      showToast('❌ ' + name + ': ' + (r.error || 'failed'), 'error');\n    }\n  } catch(e) {\n    showToast('❌ ' + name + ': ' + e.message, 'error');\n  }\n}\n\n// ═════════════════════════════════════════════════\n// CONFIG\n// ═════════════════════════════════════════════════\nfunction renderConfig(config) {\n  if (!config || !Object.keys(config).length) {\n    document.getElementById('config-display').innerHTML = '<div class=\"empty\">No config</div>';\n    return;\n  }\n  const flat = flattenObj(config);\n  const entries = Object.entries(flat);\n  document.getElementById('config-display').innerHTML =\n    `<div class=\"config-grid\">${entries.map(([k,v]) =>\n      `<span class=\"key\">${esc(k)}</span><span class=\"val\">${esc(String(v))}</span>`\n    ).join('')}</div>`;\n}\n\nfunction flattenObj(obj, prefix = '') {\n  let result = {};\n  for (const [k, v] of Object.entries(obj)) {\n    const key = prefix ? prefix + '.' + k : k;\n    if (v && typeof v === 'object' && !Array.isArray(v)) {\n      Object.assign(result, flattenObj(v, key));\n    } else if (Array.isArray(v)) {\n      result[key] = v.map(x => typeof x === 'object' ? JSON.stringify(x) : String(x)).join(', ');\n    } else {\n      result[key] = v;\n    }\n  }\n  return result;\n}\n\nfunction esc(s) {\n  if (!s) return '';\n  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\\\"/g,'&quot;');\n}\nfunction escAttr(s) { return esc(s).replace(/'/g,'&#39;'); }\n\n// ── Init ──\nloadAll();\n// Auto-refresh every 30s\nsetInterval(() => {\n  if (!document.getElementById('modal-overlay').classList.contains('show')) loadAll();\n}, 30000);\n</script>\n</body>\n</html>\n"""


def cmd_web(port=8765, open_browser=False):
    """Start the OpsTerm web dashboard server."""
    import http.server
    import json as _json
    import urllib.parse
    import webbrowser
    import subprocess
    import time
    import copy

    # Ensure dashboard HTML exists on disk
    WEB_DIR.mkdir(parents=True, exist_ok=True)
    if not WEB_INDEX.exists():
        WEB_INDEX.write_text(WEB_DASHBOARD_HTML, encoding="utf-8")
        os.chmod(str(WEB_INDEX), 0o644)

    server_addr = ("127.0.0.1", port)

    class DashboardHandler(http.server.BaseHTTPRequestHandler):
        def log_message(self, format, *args):
            pass  # Suppress default logging

        def _send_json(self, data, status=200):
            body = _json.dumps(data).encode("utf-8")
            self.send_response(status)
            self.send_header("Content-Type", "application/json")
            self.send_header("Access-Control-Allow-Origin", "*")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)

        def _send_html(self, html, status=200):
            body = html.encode("utf-8")
            self.send_response(status)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)

        def _read_body(self):
            length = int(self.headers.get("Content-Length", 0))
            if length > 0:
                return self.rfile.read(length).decode("utf-8")
            return "{}"

        def _parse_path(self):
            parsed = urllib.parse.urlparse(self.path)
            path = parsed.path.rstrip("/") or "/"
            return path

        def do_GET(self):
            path = self._parse_path()
            if path == "/api/status":
                srv = get_servers()
                wf = get_workflows()
                cfg_st = load_yaml(CONFIG_FILE)
                prov = cfg_st.get("providers", {})
                self._send_json({
                    "version": VERSION,
                    "servers_count": len(srv),
                    "workflows_count": len(wf),
                    "providers_count": len(prov),
                })
            elif path == "/api/servers":
                self._send_json({"servers": get_servers()})
            elif path == "/api/workflows":
                self._send_json({"workflows": get_workflows()})
            elif path == "/api/config":
                cfg = copy.deepcopy(load_config())
                # Mask sensitive keys
                def _mask_keys(d):
                    if isinstance(d, dict):
                        for k, v in d.items():
                            if k == "api_key" and v and isinstance(v, str):
                                d[k] = (v[:8] + "..." + v[-4:]) if len(v) > 14 else ("***" if v else "")
                            else:
                                _mask_keys(v)
                    return d
                _mask_keys(cfg)
                self._send_json({"config": cfg})
            elif path == "/api/providers":
                cfg_p = load_yaml(CONFIG_FILE)
                provs = cfg_p.get("providers", {})
                default = cfg_p.get("default_provider", "")
                masked = {}
                for name, prov in provs.items():
                    p = dict(prov)
                    key = p.pop("api_key", "")
                    p["api_key_masked"] = (key[:8] + "..." + key[-4:]) if len(key) > 14 else ("***" if key else "")
                    masked[name] = p
                self._send_json({"providers": masked, "default_provider": default})
            elif path == "/" or path == "":
                html_file = WEB_INDEX.read_text(encoding="utf-8") if WEB_INDEX.exists() else WEB_DASHBOARD_HTML
                self._send_html(html_file)
            elif path.startswith("/api/"):
                self._send_json({"error": "Not found"}, 404)
            else:
                self._send_html(WEB_DASHBOARD_HTML)

        def do_POST(self):
            path = self._parse_path()
            try:
                body = _json.loads(self._read_body())
            except _json.JSONDecodeError:
                body = {}

            if path == "/api/servers":
                name = body.get("name", "").strip()
                if not name:
                    self._send_json({"error": "Name required"}, 400)
                    return
                servers = get_servers()
                if name in servers:
                    self._send_json({"error": "Server already exists"}, 409)
                    return
                servers[name] = {
                    "host": body.get("host", ""),
                    "user": body.get("user", "root"),
                    "port": int(body.get("port", 22)),
                    "key": body.get("key", ""),
                    "desc": body.get("desc", ""),
                }
                if body.get("proxy"):
                    servers[name]["proxy"] = body["proxy"]
                save_servers(servers)
                self._send_json({"ok": True, "name": name})

            elif path.startswith("/api/workflows/run/"):
                wf_name = urllib.parse.unquote(path.split("/api/workflows/run/")[1])
                workflows = get_workflows()
                if wf_name not in workflows:
                    self._send_json({"error": f"Workflow '{wf_name}' not found"}, 404)
                    return
                # Run workflow and capture output
                import io
                old_stdout = sys.stdout
                sys.stdout = captured = io.StringIO()
                try:
                    srv = get_servers()
                    cfg = load_config()
                    run_workflow(wf_name, workflows, srv, cfg)
                except Exception as e:
                    captured.write(f"\n❌ Error: {e}")
                finally:
                    sys.stdout = old_stdout
                self._send_json({"output": captured.getvalue()})

            elif path.startswith("/api/servers/") and path.endswith("/ping"):
                name = urllib.parse.unquote(path.split("/api/servers/")[1].split("/ping")[0])
                servers = get_servers()
                if name not in servers:
                    self._send_json({"error": "Server not found"}, 404)
                    return
                srv = servers[name]
                host = srv.get("host", "")
                user = srv.get("user", "root")
                port = srv.get("port", 22)
                key = srv.get("key", "")
                start = time.time()
                cmd = ["ssh", "-o", "ConnectTimeout=5", "-o", "StrictHostKeyChecking=no", "-o", "BatchMode=yes"]
                if port != 22:
                    cmd.extend(["-p", str(port)])
                if key:
                    cmd.extend(["-i", key])
                cmd.append(f"{user}@{host}")
                cmd.append("echo pong")
                try:
                    result = subprocess.run(cmd, capture_output=True, text=True, timeout=10)
                    elapsed = time.time() - start
                    if result.returncode == 0 and "pong" in result.stdout:
                        self._send_json({"ok": True, "latency": f"{elapsed:.2f}s", "host": host})
                    else:
                        err = result.stderr.strip() or "No response"
                        self._send_json({"ok": False, "error": err, "host": host})
                except subprocess.TimeoutExpired:
                    self._send_json({"ok": False, "error": "Timeout (10s)", "host": host})
                except Exception as e:
                    self._send_json({"ok": False, "error": str(e), "host": host})

            elif path == "/api/providers":
                cfg_p = load_yaml(CONFIG_FILE)
                provs = cfg_p.setdefault("providers", {})
                name = body.get("name", "").strip()
                if not name:
                    self._send_json({"error": "Name required"}, 400)
                    return
                if name in provs:
                    self._send_json({"error": "Provider already exists"}, 409)
                    return
                provs[name] = {
                    "api_url": body.get("api_url", ""),
                    "model": body.get("model", ""),
                    "api_key": body.get("api_key", ""),
                }
                save_yaml(CONFIG_FILE, cfg_p)
                self._send_json({"ok": True, "name": name})

            elif path == "/api/workflows":
                wf_list = get_workflows()
                wf_name = body.get("name", "").strip()
                if not wf_name:
                    self._send_json({"error": "Name required"}, 400)
                    return
                if wf_name in wf_list:
                    self._send_json({"error": "Workflow already exists"}, 409)
                    return
                wf_list[wf_name] = body.get("workflow", {"steps": []})
                save_workflows(wf_list)
                self._send_json({"ok": True, "name": wf_name})

            elif path.startswith("/api/providers/test/"):
                prov_name = urllib.parse.unquote(path.split("/api/providers/test/")[1])
                cfg_p = load_yaml(CONFIG_FILE)
                provs = cfg_p.get("providers", {})
                if prov_name not in provs:
                    self._send_json({"error": "Provider not found"}, 404)
                    return
                prov = provs[prov_name]
                url = prov.get("api_url", "").rstrip("/")
                key = prov.get("api_key", "")
                import urllib.request as _ur
                test_prompt = '{"model":"' + prov.get("model", "gpt-3.5-turbo") + '","messages":[{"role":"user","content":"ping"}],"max_tokens":5}'
                try:
                    req = _ur.Request(url + "/chat/completions", data=test_prompt.encode(), headers={"Content-Type": "application/json"})
                    if key:
                        req.add_header("Authorization", f"Bearer {key}")
                    resp = _ur.urlopen(req, timeout=10)
                    result = json.loads(resp.read().decode())
                    ok = "choices" in result or "error" not in result
                    self._send_json({"ok": ok, "response": result if ok else str(result)})
                except Exception as e:
                    self._send_json({"ok": False, "error": str(e)})

            else:
                self._send_json({"error": "Not found"}, 404)

        def do_PUT(self):
            path = self._parse_path()
            try:
                body = _json.loads(self._read_body())
            except _json.JSONDecodeError:
                body = {}

            if path == "/api/config":
                updates = body.get("updates", {})
                if not updates:
                    self._send_json({"error": "No updates provided"}, 400)
                    return
                config = load_yaml(CONFIG_FILE)
                for key_path, value in updates.items():
                    parts = key_path.split(".")
                    obj = config
                    for part in parts[:-1]:
                        if part not in obj or not isinstance(obj[part], dict):
                            obj[part] = {}
                        obj = obj[part]
                    # Convert value type intelligently
                    if isinstance(obj.get(parts[-1]), bool):
                        if isinstance(value, str):
                            value = value.lower() in ("true", "1", "yes")
                    elif isinstance(obj.get(parts[-1]), (int, float)):
                        try:
                            value = type(obj.get(parts[-1]))(value)
                        except (ValueError, TypeError):
                            pass
                    obj[parts[-1]] = value
                save_yaml(CONFIG_FILE, config)
                self._send_json({"ok": True})

            elif path.startswith("/api/servers/"):
                name = urllib.parse.unquote(path.split("/api/servers/")[1])
                servers = get_servers()
                if name not in servers:
                    self._send_json({"error": "Server not found"}, 404)
                    return
                servers[name] = {
                    "host": body.get("host", servers[name].get("host", "")),
                    "user": body.get("user", servers[name].get("user", "root")),
                    "port": int(body.get("port", servers[name].get("port", 22))),
                    "key": body.get("key", servers[name].get("key", "")),
                    "desc": body.get("desc", servers[name].get("desc", "")),
                }
                if "proxy" in body and body["proxy"]:
                    servers[name]["proxy"] = body["proxy"]
                elif "proxy" in body:
                    servers[name].pop("proxy", None)
                save_servers(servers)
                self._send_json({"ok": True})

            elif path.startswith("/api/providers/") and path.endswith("/default"):
                prov_name = urllib.parse.unquote(path.split("/api/providers/")[1].split("/default")[0])
                cfg_p = load_yaml(CONFIG_FILE)
                provs = cfg_p.setdefault("providers", {})
                if prov_name not in provs:
                    self._send_json({"error": "Provider not found"}, 404)
                    return
                cfg_p["default_provider"] = prov_name
                save_yaml(CONFIG_FILE, cfg_p)
                self._send_json({"ok": True})

            elif path.startswith("/api/providers/"):
                prov_name = urllib.parse.unquote(path.split("/api/providers/")[1])
                cfg_p = load_yaml(CONFIG_FILE)
                provs = cfg_p.setdefault("providers", {})
                if prov_name not in provs:
                    self._send_json({"error": "Provider not found"}, 404)
                    return
                provs[prov_name] = {
                    "api_url": body.get("api_url", provs[prov_name].get("api_url", "")),
                    "model": body.get("model", provs[prov_name].get("model", "")),
                    "api_key": body.get("api_key", provs[prov_name].get("api_key", "")),
                }
                save_yaml(CONFIG_FILE, cfg_p)
                self._send_json({"ok": True})

            elif path.startswith("/api/workflows/"):
                wf_name = urllib.parse.unquote(path.split("/api/workflows/")[1])
                wf_list = get_workflows()
                if wf_name not in wf_list:
                    self._send_json({"error": "Workflow not found"}, 404)
                    return
                wf_list[wf_name] = body.get("workflow", wf_list[wf_name])
                save_workflows(wf_list)
                self._send_json({"ok": True})

            else:
                self._send_json({"error": "Not found"}, 404)

        def do_DELETE(self):
            path = self._parse_path()
            if path.startswith("/api/servers/"):
                name = urllib.parse.unquote(path.split("/api/servers/")[1])
                servers = get_servers()
                if name not in servers:
                    self._send_json({"error": "Server not found"}, 404)
                    return
                del servers[name]
                save_servers(servers)
                self._send_json({"ok": True})

            elif path.startswith("/api/providers/"):
                name = urllib.parse.unquote(path.split("/api/providers/")[1])
                cfg_p = load_yaml(CONFIG_FILE)
                provs = cfg_p.setdefault("providers", {})
                if name not in provs:
                    self._send_json({"error": "Provider not found"}, 404)
                    return
                del provs[name]
                if cfg_p.get("default_provider") == name:
                    cfg_p.pop("default_provider", None)
                save_yaml(CONFIG_FILE, cfg_p)
                self._send_json({"ok": True})

            elif path.startswith("/api/workflows/"):
                wf_name = urllib.parse.unquote(path.split("/api/workflows/")[1])
                wf_list = get_workflows()
                if wf_name not in wf_list:
                    self._send_json({"error": "Workflow not found"}, 404)
                    return
                del wf_list[wf_name]
                save_workflows(wf_list)
                self._send_json({"ok": True})

            else:
                self._send_json({"error": "Not found"}, 404)

        def do_OPTIONS(self):
            self.send_response(204)
            self.send_header("Access-Control-Allow-Origin", "*")
            self.send_header("Access-Control-Allow-Methods", "GET, POST, PUT, DELETE, OPTIONS")
            self.send_header("Access-Control-Allow-Headers", "Content-Type")
            self.end_headers()

    try:
        server = http.server.HTTPServer(server_addr, DashboardHandler)
        url = f"http://127.0.0.1:{port}"
        print(f"🚀 OpsTerm Dashboard  {VERSION}")
        print(f"   {url}")
        print(f"   ^C to stop")
        if open_browser:
            webbrowser.open(url)
        server.serve_forever()
    except OSError as e:
        print(f"❌ Failed to start server: {e}")
        sys.exit(1)
    except KeyboardInterrupt:
        print("\n   👋 Dashboard stopped.")
        server.server_close()


