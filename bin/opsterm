def print_server_table(servers: dict):
    if not servers:
        print("📭 No servers saved.")
        return
    header = f"{'NAMA':<20} {'HOST':<22} {'USER':<12} {'PORT':<6} {'PROXY':<15} DESKRIPSI"
    sep = "-" * 100
    print(f"\n{header}\n{sep}")
    for name, s in sorted(servers.items()):
        proxy = s.get("proxy", "") or "—"
        print(f"{name:<20} {s.get('host',''):<22} {s.get('user',''):<12} {s.get('port',22):<6} {proxy:<15} {s.get('desc','')}")

def print_workflow_table(workflows: dict):
    if not workflows:
        print("📭 No workflows saved.")
        return
    for name, w in sorted(workflows.items()):
        steps = len(w.get("steps", []))
        print(f"  ⚡ {name}")
        print(f"     {w.get('desc', '')} ({steps} step{'s' if steps != 1 else ''})")

# ═══════════════════════════════════════════════════════════
# INTERACTIVE EDITORS
# ═══════════════════════════════════════════════════════════

def _validate_hostname(host: str) -> bool:
    """Basic validation for hostname/IP to prevent injection."""
    import re
    if not host:
        return False
    # Allow hostnames, IPs, FQDNs — reject shell metacharacters
    if re.search(r'[;|&`$(){}[\]<>!#~*?\\\n\r]', host):
        return False
    return True


def _validate_username(user: str) -> bool:
    """Validate username — alphanumeric, dash, underscore only."""
    import re
    if not user:
        return False
    return bool(re.match(r'^[a-zA-Z0-9_.-]+$', user))


def _validate_ssh_key_path(path: str) -> bool:
    """Validate SSH key path — no shell metacharacters."""
    import re
    if re.search(r'[;|&`$(){}[\]<>!#~*?\\\n\r]', path):
        return False
    return True


def interactive_add_server():
    print("== Add New Server ==")
    name = input("  Nama: ").strip()
    if not name:
        print("❌ Nama wajib diisi."); return
    if not _validate_hostname(name):
        print("❌ Invalid server name (restricted characters)."); return
    servers = get_servers()
    if name in servers:
        ov = input(f"⚠️ Server '{name}' already exists. Overwrite? [y/N] ").strip().lower()
        if ov not in ("y", "yes"): return
    host = input("  Host/IP: ").strip()
    if not _validate_hostname(host):
        print("❌ Invalid hostname (restricted characters)."); return
    user = input("  User [root]: ").strip() or "root"
    if not _validate_username(user):
        print("❌ Invalid username (only alphanumeric, _, -, .)."); return
    port_str = input("  Port [22]: ").strip()
    port = int(port_str) if port_str else 22
    if port < 1 or port > 65535:
        print("❌ Port must be between 1-65535."); return
    key = input("  SSH key path [~/.ssh/id_ed25519]: ").strip() or "~/.ssh/id_ed25519"
    if not _validate_ssh_key_path(key):
        print("❌ Invalid key path (restricted characters)."); return
    desc = input("  Description: ").strip()
    proxy = input("  Proxy/jump host (server name): ").strip()
    if proxy and not _validate_hostname(proxy):
        print("❌ Invalid proxy name (restricted characters)."); return
    s = {"host": host, "user": user, "port": port, "key": key, "desc": desc}
    if proxy:
        s["proxy"] = proxy
    servers[name] = s
    save_servers(servers)
    print(f"✅ Server '{name}' ditambahkan!")

def interactive_add_workflow():
    print("== Add New Workflow ==")
    name = input("  Nama workflow: ").strip()
    if not name:
        print("❌ Nama wajib diisi."); return
    workflows = get_workflows()
    if name in workflows:
        ov = input(f"⚠️ Workflow '{name}' already exists. Overwrite? [y/N] ").strip().lower()
        if ov not in ("y", "yes"): return
    desc = input("  Description: ").strip()
    print("  Add steps (empty description to finish):")
    steps = []
    while True:
        print(f"    Step {len(steps)+1}:")
        step_type = input("      Tipe [local/ssh/scp] (local): ").strip().lower() or "local"
        step_desc = input("      Description: ").strip()
        if not step_desc:
            break
        if step_type == "scp":
            scp_src = input("      Source path: ").strip()
            scp_dst = input("      Dest path: ").strip()
            ssh_target = input("      Server (tujuan): ").strip()
            steps.append({"scp": scp_src, "to": scp_dst, "ssh": ssh_target, "desc": step_desc})
        elif step_type == "ssh":
            ssh_target = input("      Nama server: ").strip()
            step_cmd = input("      Command: ").strip()
            steps.append({"ssh": ssh_target, "command": step_cmd, "desc": step_desc})
        else:
            step_cmd = input("      Command: ").strip()
            steps.append({"command": step_cmd, "desc": step_desc})
    if not steps:
        print("❌ Minimal 1 step."); return
    workflows[name] = {"desc": desc, "steps": steps}
    save_workflows(workflows)
    print(f"✅ Workflow '{name}' ditambahkan! ({len(steps)} steps)")

