def _show_help(subcmd: str):
    """Print subcommand-specific help."""
    text = SUBCOMMAND_HELP.get(subcmd)
    if text:
        # Headers have trailing colons stripped for cleaner look
        print(text.strip())
    else:
        # Fallback: show main help
        print(f"Unknown command: {subcmd!r}. See 'opsterm --help' for usage.")


# ═══════════════════════════════════════════════════════════
# MAIN CLI
# ═══════════════════════════════════════════════════════════

def main():
    # Determine subcommand first (before consuming stdin)
    # Manual -h/--help intercept for subcommand support
    if ("-h" in sys.argv or "--help" in sys.argv) and any(a in sys.argv[1:] for a in (
        "ssh", "scp", "run", "servers", "workflows", "config", "provider",
        "vault", "history", "chat", "last", "explain-last", "explain_last",
        "init", "update", "completion", "doctor", "search", "export", "import", "reset",
    )):
        for arg in sys.argv[1:]:
            if arg in (
                "ssh", "scp", "run", "servers", "workflows", "config", "provider",
                "vault", "history", "chat", "last", "explain-last", "explain_last",
                "init", "update", "completion", "doctor", "search", "export", "import", "reset",
            ):
                _show_help(arg)
                return
        return

    parser = argparse.ArgumentParser(
        prog="opsterm",
        description="OpsTerm — AI Terminal Assistant. Custom AI provider + servers, workflows, multi-hop SCP, vault.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            Core Commands:
              <prompt>                     Ask AI — get command suggestions, explain output
              ssh <server> [--via <proxy>] SSH to server (fuzzy name match, ProxyJump)
              scp <src> <dst>              Transfer files (local:path, server:path, --via)
              run <workflow>               Execute a multi-step YAML workflow

            Management Commands:
              servers <action> [<name>]      Manage server list — list, add, edit, rm, show, ping, rename, import-ssh-config
              workflows <action> [<name>]    Manage workflow list — list, add, edit, rm, init
              provider <action> [<name>]     Manage AI providers — list, add, rm, default, test, models, supported
              config <action> [<key>]        Manage config — list, get, set, validate
              vault <action> [<args>]        Encrypted credential store — init, set, get, list, rm, lock

            Utility Commands:
              history [<limit>]              Show past queries (default: 20)
              search <query>                 Search chat history
              chat [--continue, -c]          Interactive chat REPL (--continue to resume)
              last                           View the last shell command's output
              explain-last                   Explain last command output with AI
              init                           Initialize config directory (~/.opsterm)
              update                         Check and install latest version
              doctor                         Diagnose installation and configuration
              export [<file>]                Export config to tar.gz (API keys masked)
              import <file>                  Import config from tar.gz
              reset                          Reset config to defaults
              completion <shell>             Generate tab completion (bash|zsh)

            Pipe Mode:
              cmd | opsterm [<prompt>]       Pipe command output to AI for analysis

            Examples:
              opsterm how to find large files
              opsterm ssh vps-utama
              opsterm ssh internal --via bastion
              opsterm scp file.txt vps-utama:/home/ubuntu/
              opsterm run deploy-app
              opsterm config set ai.response_style concise
              opsterm provider add openai --api-key sk-... --model gpt-4o
              opsterm vault set db_password
              docker ps | opsterm "any errors?"

            Learn more: https://github.com/edsuwarna/opsterm
        """),
    )
    parser.add_argument("-v", "--version", action="version", version=f"%(prog)s {VERSION}")
    parser.add_argument("--verbose", "-V", action="store_true", help="Detailed AI response (verbose mode)")
    parser.add_argument("--concise", "-C", action="store_true", help="Concise AI response (override config)")
    parser.add_argument("--json", action="store_true", help="Output in JSON format (for list commands)")
    parser.add_argument("args", nargs="*", help="Command or prompt")
    known_args, extra = parser.parse_known_args()
    raw_args = known_args.args + extra  # keep --flags for provider subcommand
    # Read stdin data for pipe mode
    stdin_data = ""
    if not sys.stdin.isatty():
        try:
            stdin_data = sys.stdin.read()
        except Exception:
            pass
    if not raw_args and not stdin_data:
        parser.print_help()
        return

    subcmd = raw_args[0] if raw_args else ""

    # ── subcommand --help ──
    if "-h" in raw_args or "--help" in raw_args:
        _show_help(subcmd)
        return

    # ── Auto-init on first use ──
    if subcmd not in ("init",):
        _ensure_config()

    # ── doctor ──
    if subcmd == "doctor":
        cmd_doctor()
        return

    # ── version check (pasif, 1x/24jam) ──
    if subcmd not in ("doctor", "update", "completion", "init"):
        _check_version_startup()

    # ── search ──
    if subcmd == "search":
        query = " ".join(raw_args[1:]) if len(raw_args) > 1 else ""
        if not query:
            print("Usage: opsterm search <query>")
            return
        cmd_search(query, use_json=known_args.json)
        return

    # ── update ──
    if subcmd == "update":
        cmd_update()
        return

    # ── completion ──
    if subcmd == "completion":
        if len(raw_args) > 1 and raw_args[1] == "install":
            cmd_completion_install()
            return
        shell = raw_args[1] if len(raw_args) > 1 else "bash"
        if shell == "bash":
            print(COMPLETION_BASH)
        elif shell == "zsh":
            print(COMPLETION_ZSH)
        else:
            print("❌ Shell not supported. Use: bash, zsh, or install")
        return

    # ── init ──
    if subcmd == "init":
        do_init()
        return

    # ── config ──
    elif subcmd == "config":
        cfg = load_config()
        if len(raw_args) == 1:
            print(_dump_yaml(cfg))
        elif raw_args[1] == "list":
            print(_dump_yaml(cfg))
        elif raw_args[1] == "get" and len(raw_args) > 2:
            key = raw_args[2]
            parts = key.split(".")
            val = cfg
            for p in parts:
                val = val.get(p, {}) if isinstance(val, dict) else "❌ Key not found"
            print(val)
        elif raw_args[1] == "set" and len(raw_args) > 3:
            key = raw_args[2]
            val = raw_args[3]
            current = load_yaml(CONFIG_FILE)
            parts = key.split(".")
            d = current
            for p in parts[:-1]:
                d = d.setdefault(p, {})
            # Validate common keys
            parsed = _parse_scalar(val)
            if key == "ai.response_style":
                if val not in ("concise", "detailed"):
                    print(f"❌ Invalid value '{val}' for ai.response_style. Use: concise or detailed")
                    return
            elif key == "ai.temperature":
                if not isinstance(parsed, (int, float)) or parsed < 0 or parsed > 2:
                    print(f"❌ temperature must be a number between 0 and 2.")
                    return
            elif key == "ai.system_prompt":
                # Store as raw string, skip _parse_scalar
                d[parts[-1]] = val
                save_yaml(CONFIG_FILE, current)
                print(f"✅ {key} = {val}")
                return
            elif key == "ai.max_tokens":
                if not isinstance(parsed, (int, float)) or parsed < 1:
                    print(f"❌ max_tokens must be a positive number.")
                    return
            elif key in ("shell.confirm_before_exec", "rtk.enabled", "rtk.auto_detect", "rtk.ultra_compact"):
                if parsed not in (True, False):
                    print(f"❌ '{key}' must be true or false.")
                    return
            d[parts[-1]] = parsed
            save_yaml(CONFIG_FILE, current)
            print(f"✅ {key} = {val}")
        elif raw_args[1] == "validate":
            print("🔍 Validating configuration...")
            if cmd_validate_config():
                print("\n✅ All configuration files are valid!")
            else:
                print("\n⚠️  Some issues found — see above.")
        else:
            print("Usage: opsterm config [list|get <key>|set <key> <value>]")

    # ── provider ──
    elif subcmd == "provider":
        do_provider(raw_args, use_json=known_args.json)

    # ── servers ──
    elif subcmd == "servers":
        servers = get_servers()
        if len(raw_args) == 1:
            print_server_table(servers)
            print(f"\n  Total: {len(servers)} server(s)")
            print("  Usage: opsterm servers [list|add|edit <name>|rm <name>|ping <name>|show <name>]")
        elif raw_args[1] == "list":
            if hasattr(known_args, 'json') and known_args.json:
                import json as _json
                print(_json.dumps(servers, indent=2))
            else:
                print_server_table(servers)
        elif raw_args[1] == "show" and len(raw_args) > 2:
            target = raw_args[2]
            srv = servers.get(target)
            if not srv:
                exact = _fuzzy_match(target, servers)
                if not exact:
                    print(f"❌ Server '{target}' not found.")
                    return
                srv = servers[exact]
                target = exact
            print(f"\n  ┌─ \033[1m{target}\033[0m " + "─" * 50)
            print(f"  │ Host:        {srv.get('host', '')}")
            print(f"  │ User:        {srv.get('user', 'root')}")
            print(f"  │ Port:        {srv.get('port', 22)}")
            print(f"  │ SSH Key:     {srv.get('key', '—') or '—'}")
            print(f"  │ Proxy:       {srv.get('proxy', '—') or '—'}")
            print(f"  │ Description: {srv.get('desc', '—') or '—'}")
            print(f"  └" + "─" * 60)
        elif raw_args[1] == "ping" and len(raw_args) > 2:
            target = raw_args[2]
            srv = servers.get(target)
            if not srv:
                exact = _fuzzy_match(target, servers)
                if not exact:
                    print(f"❌ Server '{target}' not found.")
                    return
                srv = servers[exact]
            host = srv.get("host", "")
            user = srv.get("user", "root")
            port = srv.get("port", 22)
            key = srv.get("key", "")
            print(f"  🏓 Pinging '{target}' ({user}@{host}:{port})...")
            start = time.time()
            cmd = ["ssh", "-o", "ConnectTimeout=5", "-o", "StrictHostKeyChecking=no", "-o", "BatchMode=yes"]
            if port != 22:
                cmd.extend(["-p", str(port)])
            if key:
                cmd.extend(["-i", key])
            cmd.append(f"{user}@{host}")
            cmd.append("echo pong")
            try:
                result = subprocess.run(cmd, capture_output=True, text=True, timeout=10)
                elapsed = time.time() - start
                if result.returncode == 0 and "pong" in result.stdout:
                    print(f"  ✅ Connected! ({elapsed:.1f}s)")
                else:
                    err = result.stderr.strip()[:200]
                    print(f"  ❌ Failed ({elapsed:.1f}s): {err}")
            except subprocess.TimeoutExpired:
                print(f"  ❌ Timeout (>10s)")
            except Exception as e:
                print(f"  ❌ Error: {e}")
        elif raw_args[1] == "add":
            interactive_add_server()
        elif raw_args[1] == "edit" and len(raw_args) > 2:
            target = raw_args[2]
            if target not in servers:
                print(f"❌ Server '{target}' not found."); return
            print(f"Edit server '{target}' (leave empty to skip):")
            s = servers[target]
            host = input(f"  Host [{s.get('host','')}]: ").strip() or s.get('host','')
            if host and not _validate_hostname(host):
                print("❌ Invalid hostname (restricted characters)."); return
            user = input(f"  User [{s.get('user','')}]: ").strip() or s.get('user','')
            if user and not _validate_username(user):
                print("❌ Invalid username (only alphanumeric, _, -, .)."); return
            port_str = input(f"  Port [{s.get('port',22)}]: ").strip()
            port = int(port_str) if port_str else s.get('port',22)
            if port < 1 or port > 65535:
                print("❌ Port must be between 1-65535."); return
            key = input(f"  SSH key [{s.get('key','')}]: ").strip() or s.get('key','')
            if key and not _validate_ssh_key_path(key):
                print("❌ Invalid key path (restricted characters)."); return
            desc = input(f"  Description [{s.get('desc','')}]: ").strip() or s.get('desc','')
            proxy = input(f"  Proxy [{s.get('proxy','')}]: ").strip() or s.get('proxy','')
            if proxy and not _validate_hostname(proxy):
                print("❌ Invalid proxy name (restricted characters)."); return
            servers[target] = {"host": host, "user": user, "port": port, "key": key, "desc": desc}
            if proxy:
                servers[target]["proxy"] = proxy
            save_servers(servers)
            print(f"✅ Server '{target}' updated!")
        elif raw_args[1] == "rm" and len(raw_args) > 2:
            target = raw_args[2]
            if target in servers:
                confirm = input(f"Delete server '{target}'? [y/N] ").strip().lower()
                if confirm in ("y", "yes"):
                    del servers[target]
                    save_servers(servers)
                    print(f"✅ Server '{target}' removed.")
            else:
                print(f"❌ Server '{target}' not found.")
        elif raw_args[1] == "rename" and len(raw_args) > 3:
            old_name = raw_args[2]
            new_name = raw_args[3]
            if old_name not in servers:
                print(f"❌ Server '{old_name}' not found.")
                return
            if new_name in servers:
                print(f"❌ Server '{new_name}' already exists.")
                return
            servers[new_name] = servers.pop(old_name)
            save_servers(servers)
            print(f"✅ Server '{old_name}' → '{new_name}'")
        elif raw_args[1] == "import-ssh-config":
            old_count = len(servers)
            servers = cmd_import_ssh_config(servers)
            if len(servers) > old_count:
                save_servers(servers)
        else:
            print("Usage: opsterm servers [list|add|edit <name>|rm <name>|ping <name>|show <name>]")

    # ── workflows ──
    elif subcmd == "workflows":
        workflows = get_workflows()
        if len(raw_args) == 1:
            print_workflow_table(workflows)
            print(f"\n  Total: {len(workflows)} workflow(s)")
            print("  Usage: opsterm workflows [list|add|edit|rm]")
        elif raw_args[1] == "list":
            print_workflow_table(workflows)
        elif raw_args[1] == "add":
            interactive_add_workflow()
        elif raw_args[1] == "edit" and len(raw_args) > 2:
            target = raw_args[2]
            if target not in workflows:
                print(f"❌ Workflow '{target}' not found."); return
            print(f"📝 Edit workflow '{target}' — edit the file directly:")
            print(f"   {WORKFLOWS_FILE}")
            editor = os.environ.get("EDITOR", "nano")
            subprocess.run([editor, str(WORKFLOWS_FILE)])
        elif raw_args[1] == "rm" and len(raw_args) > 2:
            target = raw_args[2]
            if target in workflows:
                confirm = input(f"Delete workflow '{target}'? [y/N] ").strip().lower()
                if confirm in ("y", "yes"):
                    workflows = get_workflows()
                    del workflows[target]
                    save_workflows(workflows)
                    print(f"✅ Workflow '{target}' removed.")
            else:
                print(f"❌ Workflow '{target}' not found.")
        elif raw_args[1] == "init":
            cmd_workflow_init()
        else:
            print("Usage: opsterm workflows [list|add|edit <name>|rm <name>]")

    # ── ssh (with --via / multi-hop, --all for batch) ──
    elif subcmd == "ssh" and len(raw_args) > 1:
        if "--all" in raw_args:
            command = " ".join(a for a in raw_args[2:] if a != "--all")
            if not command:
                print("Usage: opsterm ssh --all <command>")
                return
            servers = get_servers()
            cmd_ssh_all(command, servers)
            return
        server_name = raw_args[1]
        proxy_name = ""
        if "--via" in raw_args:
            idx = raw_args.index("--via")
            if idx + 1 < len(raw_args):
                proxy_name = raw_args[idx + 1]
        elif "-v" in raw_args:
            idx = raw_args.index("-v")
            if idx + 1 < len(raw_args):
                proxy_name = raw_args[idx + 1]

        servers = get_servers()
        cmd = ssh_connect(server_name, servers, proxy_name)
        if cmd:
            via_str = f" via {proxy_name}" if proxy_name else ""
            add_history("ssh", f"ssh {server_name}{via_str}")
            print(f"🔑 Connecting to {server_name}{via_str}...")
            run_ssh(cmd)

    # ── scp ──
    elif subcmd == "scp" and len(raw_args) >= 3:
        source = raw_args[1]
        dest = raw_args[2]
        proxy_name = ""
        if "--via" in raw_args:
            idx = raw_args.index("--via")
            if idx + 1 < len(raw_args):
                proxy_name = raw_args[idx + 1]
        elif "-v" in raw_args:
            idx = raw_args.index("-v")
            if idx + 1 < len(raw_args):
                proxy_name = raw_args[idx + 1]
        servers = get_servers()
        via_str = f" via {proxy_name}" if proxy_name else ""
        add_history("scp", f"{source} → {dest}{via_str}")
        scp_transfer(source, dest, servers, proxy_name)

    # ── vault ──
    elif subcmd == "vault":
        vault = Vault()
        if len(raw_args) == 1:
            print("🔐 OpsTerm Vault — Encrypted Credential Store")
            print("  init   — Buat vault baru")
            print("  set    — Simpan credential (opsterm vault set <key>)")
            print("  get    — Ambil credential (opsterm vault get <key>)")
            print("  list   — Lihat semua key")
            print("  rm     — Remove key")
            print("  lock   — Kunci vault")
            print(f"\n  File: {VAULT_FILE}")
            print("  Env:   OPSTERM_VAULT_PASSWORD")
            return
        action = raw_args[1]
        if action == "init":
            vault.init()
        elif action == "set":
            key = raw_args[2] if len(raw_args) > 2 else ""
            if not key:
                print("Usage: opsterm vault set <key> [value]")
                print("  (value optional, akan di-prompt jika kosong)")
                return
            value = " ".join(raw_args[3:]) if len(raw_args) > 3 else ""
            vault.set(key, value)
            add_history("vault", f"set {key}")
        elif action == "get":
            key = raw_args[2] if len(raw_args) > 2 else ""
            if not key:
                print("Usage: opsterm vault get <key>")
                return
            value = vault.get(key)
            if value:
                print(value)
        elif action == "list":
            vault.list_keys()
        elif action == "rm":
            key = raw_args[2] if len(raw_args) > 2 else ""
            if not key:
                print("Usage: opsterm vault rm <key>")
                return
            vault.rm(key)
        elif action == "lock":
            vault.lock()
        else:
            print(f"❌ Unknown vault action: {action}")

    # ── last ──
    elif subcmd == "last":
        out, cmd = get_last_output()
        if not out and not cmd:
            print("📭 No saved output yet.")
            print("   Last command auto-saved by zsh plugin.")
            print("   Without plugin: use pipe mode | opsterm explain")
        else:
            if cmd:
                print(f"💻 Command: {cmd}")
            if out:
                print(f"📄 Output:\n{out[:2000]}")

    # ── explain-last ──
    elif subcmd in ("explain-last", "explain_last"):
        out, cmd = get_last_output()
        if not out and not cmd:
            print("📭 No output to explain yet.")
            print("   Run a command first, or pipe: cmd | opsterm explain")
            return
        config = load_config()
        # ── RTK: filter saved output before AI context ──
        rtk_cfg = config.get("rtk", {})
        ctx_out = out
        if rtk_cfg.get("enabled", True) and _rtk_available() and out:
            filtered = _rtk_pipe(out)
            if filtered and len(filtered) < len(out):
                ctx_out = filtered
        prompt = f"Explain this output from command '{cmd}':\n```\n{ctx_out[:3000]}\n```"
        # Determine style override from flags
        style_override = None
        if known_args.verbose:
            style_override = "detailed"
        elif known_args.concise:
            style_override = "concise"
        response = generate_command(prompt, config, style_override=style_override)
        add_history("pipe" if out else "ai", cmd or "(last)", response)
        print(response)

    # ── run ──
    elif subcmd == "run" and len(raw_args) > 1:
        wf_name = raw_args[1]
        config = load_config()
        servers = get_servers()
        workflows = get_workflows()
        add_history("workflow", f"run {wf_name}")
        run_workflow(wf_name, workflows, servers, config)

    # ── chat ──
    elif subcmd == "chat":
        cmd_chat(raw_args)

    # ── history ──
    elif subcmd == "history":
        limit = int(raw_args[1]) if len(raw_args) > 1 and raw_args[1].isdigit() else 20
        show_history(limit, use_json=known_args.json)

    # ── export ──
    elif subcmd == "export":
        path = raw_args[1] if len(raw_args) > 1 else ""
        cmd_export(path)

    # ── import ──
    elif subcmd == "import":
        path = raw_args[1] if len(raw_args) > 1 else ""
        if not path:
            print("Usage: opsterm import <file.tar.gz>")
            return
        cmd_import(path)

    # ── reset ──
    elif subcmd == "reset":
        cmd_reset()

    # ── web dashboard ──
    elif subcmd == "web":
        port = 8765
        open_browser = False
        i = 1
        while i < len(raw_args):
            if raw_args[i] in ("--port", "-p") and i + 1 < len(raw_args):
                try:
                    port = int(raw_args[i + 1])
                    i += 2
                    continue
                except ValueError:
                    pass
            elif raw_args[i] in ("--open", "-o"):
                open_browser = True
            i += 1
        cmd_web(port=port, open_browser=open_browser)

    # ── AI mode (default) ──
    else:
        prompt = " ".join(raw_args) if raw_args else ""
        if not prompt and stdin_data:
            prompt = "Jelaskan output ini"
        if not prompt:
            print("❌ Masukkan pertanyaan.")
            return

        # Determine style override from flags
        style_override = None
        if known_args.verbose:
            style_override = "detailed"
        elif known_args.concise:
            style_override = "concise"

        config = load_config()
        response = generate_command(prompt, config, stdin_data, style_override=style_override)
        add_history("pipe" if stdin_data else "ai", prompt, response)
        print(response)

        # Auto-exec suggestion — smart: read-only auto-runs, write asks
        shell_cfg = config.get("shell", {})
        auto_patterns = shell_cfg.get("auto_exec_patterns", [])
        auto_regexes = [re.compile(p) for p in auto_patterns]

        if shell_cfg.get("confirm_before_exec", True):
            lines = response.strip().split("\n")
            exec_candidates = []
            for line in lines:
                line_s = line.strip()
                if line_s.startswith("$ "):
                    exec_candidates.append(line_s[2:])
            if exec_candidates:
                print()
                for candidate in exec_candidates:
                    # 1) Matches user-defined auto_exec_patterns? → auto-run
                    if any(pat.search(candidate) for pat in auto_regexes):
                        print(f"  ⚡ {candidate}")
                        result = subprocess.run(shlex.split(candidate), capture_output=True)
                        out = result.stdout.decode() + result.stderr.decode()
                        _save_last_output(out, candidate)
                        if out:
                            print(out[:2000])
                        add_history("shell", candidate)
                        continue
                    # 2) Destructive? → always ask
                    if _is_destructive_cmd(candidate):
                        try:
                            resp = input(f"  ⚠️ {candidate}? [y/N] ").strip().lower()
                        except (EOFError, KeyboardInterrupt):
                            resp = "n"
                        if resp in ("y", "yes"):
                            result = subprocess.run(shlex.split(candidate), capture_output=True)
                            out = result.stdout.decode() + result.stderr.decode()
                            _save_last_output(out, candidate)
                            if out:
                                print(out[:2000])
                            add_history("shell", candidate)
                            _save_last_output(out, candidate)
                        continue
                    # 3) Read-only? → auto-run
                    if _is_readonly_cmd(candidate):
                        print(f"  ⚡ {candidate}")
                        result = subprocess.run(shlex.split(candidate), capture_output=True)
                        out = result.stdout.decode() + result.stderr.decode()
                        _save_last_output(out, candidate)
                        if out:
                            print(out[:2000])
                        add_history("shell", candidate)
                        continue
                    # 4) Unknown/unclassified? → ask
                    try:
                        resp = input(f"  💻 Jalanin: {candidate}? [y/N] ").strip().lower()
                    except (EOFError, KeyboardInterrupt):
                        resp = "n"
                    if resp in ("y", "yes"):
                        result = subprocess.run(shlex.split(candidate), capture_output=True)
                        out = result.stdout.decode() + result.stderr.decode()
                        _save_last_output(out, candidate)
                        if out:
                            print(out[:2000])
                        add_history("shell", candidate)
                        _save_last_output(out, candidate)

if __name__ == "__main__":
    main()
